        .section    ".text","ax"

/*===================================================================================================================================*/
/*  U4      u4_g_SumU4(const U4 * u4_ap_WORD, const U2 u2_a_NUM_WORD)                                                                */
/* --------------------------------------------------------------------------------------------------------------------------------- */
/*  Arguments:      -                                                                                                                */
/*  Return:         -                                                                                                                */
/*===================================================================================================================================*/
_u4_g_SumU4:
        mov     r0,             r10                                  /* sum = 0                                           */

        cmp     r0,             r6
        be      eculib_sum_u4_end                                    /* if(u4_ap_WORD == NULL(0)), then eculib_sum_u4_end */
        cmp     r0,             r7
        be      eculib_sum_u4_end                                    /* if(u4_a_NUM_WORD == 0U), then eculib_sum_u4_end   */

        shl     0x02,           r7

        mov     0x04,           r8
        and     r6,             r8
        cmp     r0,             r8
        be      eculib_sum_u4_32b_init                               /* if(r8 == 0U), then eculib_sum_u4_32b_init         */

        ld.w    0x0000[r6],     r10
        add     r8,             r6
        sub     r8,             r7

eculib_sum_u4_32b_init:
        movea   0x0020,         r0,             r8
        cmp     r8,             r7
        bl      eculib_sum_u4_16b_init                               /* if(r7 < 32U), then eculib_sum_u4_16b_init         */

eculib_sum_u4_32b_next:
        ld.dw   0x0000[r6],     r12
        ld.dw   0x0008[r6],     r14
        ld.dw   0x0010[r6],     r16
        ld.dw   0x0018[r6],     r18

        add     r12,            r10
        add     r13,            r10
        add     r14,            r10
        add     r15,            r10
        add     r16,            r10
        add     r17,            r10
        add     r18,            r10
        add     r19,            r10

        add     r8,             r6                                   /* r6 = r6 + 32                                      */
        sub     r8,             r7                                   /* r7 = r7 - 32                                      */
        cmp     r8,             r7
        bnl     eculib_sum_u4_32b_next                                 /* if(r7 >= 32U), then eculib_sum_u4_32b_next      */

eculib_sum_u4_16b_init:
        movea   0x0010,         r0,             r8
        cmp     r8,             r7
        bl      eculib_sum_u4_8b_init                                /* if(r7 >= 16U), then eculib_sum_u4_8b_init         */

        ld.dw   0x0000[r6],     r12
        ld.dw   0x0008[r6],     r14

        add     r12,            r10
        add     r13,            r10
        add     r14,            r10
        add     r15,            r10

        add     r8,             r6                                   /* r6 = r6 + 16                                      */
        sub     r8,             r7                                   /* r7 = r7 - 16                                      */

eculib_sum_u4_8b_init:
        mov     0x08,           r8
        cmp     r8,             r7
        bl      eculib_sum_u4_4b_init                                /* if(r7 >= 4U), then eculib_sum_u4_4b_init          */

        ld.dw   0x0000[r6],     r12

        add     r12,            r10
        add     r13,            r10

        add     r8,             r6                                   /* r6 = r6 + 8                                       */
        sub     r8,             r7                                   /* r7 = r7 - 8                                       */

eculib_sum_u4_4b_init:
        mov     0x04,           r8
        cmp     r8,             r7
        bl      eculib_sum_u4_end                                    /* if(r7 < 4U), then eculib_sum_u4_end               */

        ld.w    0x0000[r6],     r12
        add     r12,            r10

eculib_sum_u4_end:
        jmp     [lp]

