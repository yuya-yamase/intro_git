    .GLOBAL     _vd_g_Gpt_BusyWait
    .ALIGN      16

/*===================================================================================================================================*/
/*  void    vd_g_Gpt_BusyWait(const U2 u2_a_THRSH)                                                                                   */
/* --------------------------------------------------------------------------------------------------------------------------------- */
/*  Arguments:      -                                                                                                                */
/*  Return:         -                                                                                                                */
/*===================================================================================================================================*/
_vd_g_Gpt_BusyWait:
;/* ;r6     parameters  lsb:count   */
                                                    ;/* ; Step    ; Cycle     */    ;/*Cycle(sum)     */
    cmp         r0, r6                              ;/* ; #1      ; 1       ; */    ;/* +1            */
    be          END                                 ;/* ; #2      ; 2-6     ; */    ;/* +3-7          */
    shl         3, r6                               ;/* ; #1      ; 1       ; */    ;/* +1            */
LOOP:                                               ;/* 1 loop = 5 cycle */
    syncp                                           ;/* ; #2      ; 3       ; */    ;/* +4            */
    loop        r6, LOOP                            ;/* ; #3      ; 2       ; */    ;/* +6            */

END:                                                                                ;/* +3(4-1)       */
    jmp         [lp]                                ;/* ; L4      ; 2-6     ; */    ;/* +2-6          */

    .TYPE       _vd_g_Gpt_BusyWait,                     @function
    .SIZE       _vd_g_Gpt_BusyWait,                     .-_vd_g_Gpt_BusyWait
