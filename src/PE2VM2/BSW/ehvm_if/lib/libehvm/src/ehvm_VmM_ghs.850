    .global _ehvm_vmm_reset_vm_hvc
    .type   _ehvm_vmm_reset_vm_hvc, @function
_ehvm_vmm_reset_vm_hvc:
    pushsp lp - lp                              /* lp */
    pushsp r12 - r16
    pushsp r1 - r1
    mov VM_RESET_VM_FUNC, r12  /* set functionID */
    mov r6, r13  /* set resettyp */
    mov r7, r14  /* set contextId */
    mov r8, r15  /* set vm_exit_factor */
    mov r9, r16  /* set vm_action */
    hvtrap 0x00  /* exec Hyper Visor Call */
    mov r1, r10  /* set return value */
    popsp  r1 - r1
    popsp  r12 - r16
    popsp  lp - lp                              /* lp */
    jmp    lp

