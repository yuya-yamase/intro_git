    .global _ehvm_vmm_get_vm_status_table_hvc
    .type   _ehvm_vmm_get_vm_status_table_hvc, @function
_ehvm_vmm_get_vm_status_table_hvc:
    pushsp lp - lp                              /* lp */
    pushsp r12 - r13
    pushsp r1 - r1
    mov VM_GET_STARTUP_STATUS_FUNC, r12  /* set functionID */
    mov r6, r13  /* set vm_current_status */
    hvtrap 0x00  /* exec Hyper Visor Call */
    mov r1, r10  /* set return value */
    popsp  r1 - r1
    popsp  r12 - r13
    popsp  lp - lp                              /* lp */
