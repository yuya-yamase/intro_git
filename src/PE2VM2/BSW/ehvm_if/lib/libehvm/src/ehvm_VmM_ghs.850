/****************************************************************************
[ehvm_VmM_ghs.850] - EHVM assembly implements for v850
****************************************************************************/
    .file "ehvm_VmM_ghs.850"

#define VM_EXIT_FUNC                             4
#define VM_RESET_FACTOR_FUNC                     5
#define VM_ENABLE_SUPPRESS_VM_NORMAL_FUNC        13
#define VM_DISABLE_SUPPRESS_VM_NORMAL_FUNC      14
#define VM_GET_STARTUP_STATUS_FUNC              15
#define VM_RESET_VM_FUNC                        16
#define VM_GET_WAKEUP_FACTOR_FUNC               18
#define VM_SET_WAKEUP_FACTOR_FUNC               19
#define VM_CLEAR_WAKEUP_FACTOR_FUNC             20
#define VM_ENABLE_WAKEUP_FACTOR_FUNC            21
#define VM_DISABLE_WAKEUP_FACTOR_FUNC           22
#define VM_VM_STATUSCHK_FUNC                    23




    .global _ehvm_vmm_exit_hvc
    .type   _ehvm_vmm_exit_hvc, @function
_ehvm_vmm_exit_hvc:
    pushsp lp - lp                              /* lp */
    pushsp r12 - r14
    pushsp r1 - r1
    mov VM_EXIT_FUNC, r12  /* set functionID */
    mov r6, r13  /* set exit factor */
    mov r7, r14  /* set vm action */
    hvtrap 0x00  /* exec Hyper Visor Call */
    mov r1, r10  /* set return value */
    popsp  r1 - r1
    popsp  r12 - r14
    popsp  lp - lp                              /* lp */
    jmp    lp

    .global _ehvm_vmm_get_reset_factor_hvc
    .type   _ehvm_vmm_get_reset_factor_hvc, @function
_ehvm_vmm_get_reset_factor_hvc:
    pushsp lp - lp                              /* lp */
