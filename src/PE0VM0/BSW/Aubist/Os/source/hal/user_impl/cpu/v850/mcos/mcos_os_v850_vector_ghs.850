    .align  16
EIINT_PRI15_3: /* 0x1F0: EIINTn (priority 15) */
    jr      _mcos_v850_undefint_entry           /* call user routine */

    .size   _mcos_v850_ebase_3, .-_mcos_v850_ebase_3

#endif /* #if (MP_CONTROL_CORE_COUNT > 3) */

#define OS_STOP_SEC_CODE_SHARED
#include "Os_MemMap.h"

