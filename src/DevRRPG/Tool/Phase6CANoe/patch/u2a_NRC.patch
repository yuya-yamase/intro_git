+void sendTransferDataApl(diagRequest * objectName, byte blockSequenceCounter[], int transfer_size)
+{
+    int ret;
+    dword readSize;
+    G_Bsc_Reprog_General_Data.T_Info_Reprog.transfer_size = transfer_size - 2;
+    TransferData_read_file( G_Bsc_Reprog_General_Data.T_Info_Reprog.filehandle,
+                                  G_Bsc_Reprog_General_Data.T_Info_Reprog.transfer_size,
+                                  transferdata_readbuff,
+                                  readSize );
+        
+    diagSetParameterRaw(objectName, "blockSequenceCounter", blockSequenceCounter, elcount(blockSequenceCounter));
+    diagSetParameterRaw(objectName, "transferRequestParameterRecord", transferdata_readbuff, elcount(transferdata_readbuff));
+    diagResize(objectName, transfer_size);
+
+    diagSendRequest(objectName);
+    if( TestWaitForDiagRequestSent(objectName, 2000) == 1 )
+    {    
+        TestReportWriteDiagObject(objectName);
+        if( TestWaitForDiagResponse(objectName, timeout) == 1 )
+        {
+            TestReportWriteDiagResponse(objectName);
+        }
+    }
+}
