+void setupTransferDataApl()
+{
+    int ret;
+    ret = TransferData_open_file(G_Bsc_Reprog_General_Data.T_Info_Reprog.filename, E_Openfile_mode_text,
+                     G_Bsc_Reprog_General_Data.T_Info_Reprog.filehandle );
