/// <TesterPresent>
/* ************************************************************************* */
/* Function                                                                  */
/*  TesterPresent_request_01_send                                            */
/* Discription                                                               */
/*  Send Request Sid0x3E [TesterPresent]                                     */
/* IN :                                                                      */
/*  None                                                                     */
/* OUT:                                                                      */
/*  None                                                                     */
/* RET:                                                                      */
/*  diagSendRequest()の処理結果                                              */
/* NOTE                                                                      */
/*  SPRMIB付きのリクエストを送信する関数を用意するのでこの関数では設定不要   */
/* ************************************************************************* */
long TesterPresent_request_01_send( void )
{
  /* 戻り値 */
  int ret;

  if( G_Reprog_General_Data.TP_Info.testerPresentAddrtype == E_Send_Address_Phy )
  {
    /* リクエスト送信(物理アドレス) */
    ret = diagSendRequest(G_TesterPresent_req_01);
  }
  else if( G_Reprog_General_Data.TP_Info.testerPresentAddrtype == E_Send_Address_Func )
  {
    /* リクエスト送信(機能アドレス) */
    ret = diagSendFunctional(G_TesterPresent_req_01);
  }
  else
  {
    /* パラメータエラー */
    ret = E_Return_PRAMETER_NG;    
  }
  
  /* リクエスト送信の戻り値を返す */
  return ret;   
}


