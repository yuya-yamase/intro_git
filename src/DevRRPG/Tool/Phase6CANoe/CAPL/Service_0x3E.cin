/// <TesterPresent>
/* ********************************************************************* */
/* Function                                                              */
/*  TesterPresent_init                                                   */
/* Discription                                                           */
/*  外部設定情報ファイルを読み出してSid0x3Eのパラメータを設定する        */
/* IN :                                                                  */
/*  filename : 外部設定情報ファイル名                                    */
/* OUT:                                                                  */
/*  None                                                                 */
/* RET:                                                                  */
/*  None                                                                 */
/* NOTE:                                                                 */
/*  読み出し失敗時はデフォルトの設定となる                               */
/* ********************************************************************* */
void TesterPresent_init( char filename[] )
{
  /* ファイル読み出し(SID 0x3Eのアドレス種別) */
  /* 読み出し失敗時は「物理アドレス」を使用する設定 */
  G_Reprog_General_Data.TP_Info.testerPresentAddrtype =
                         getProfileInt("TesterPresent", "addrtype", 0x0, filename); 
  
  /* ファイル読み出し(SID 0x3EのSPRMIB) */
  /* 読み出し失敗時は「SPRMIB無し」を使用する設定 */
  G_Reprog_General_Data.TP_Info.testerPresentSprmib =
                         getProfileInt("TesterPresent", "sprmib", 0x0, filename); 

  return;
}
