/// <DiagnosticSessionControl>
/* ******************************************************** */
/* Function                                                 */
/*  DiagnosticSessionControl_request_01_send                */
/* Discription                                              */
/*  Send Request Sid0x10 [DiagnosticSessionControl]         */
/* IN :                                                     */
/*  addrtype : 機能/物理アドレスの指定                      */
/*  sprmib : SPRMIB有効フラグ(E_FLAG_ON=ならSPRMIBを付与)   */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSendRequest()の処理結果 または                      */
/*  E_Return_SPRMIB_Set_NG                                  */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long DiagnosticSessionControl_request_01_send( int addrtype, long sprmib )
{
  /* 戻り値 */
  int ret;
 
  /* アドレス指定によって物理アドレスか機能アドレスのどちらに送信するか判定 */
  if ( addrtype == E_Send_Address_Phy )
  {
    /* 物理アドレスにリクエスト送信 */
    /* 物理アドレスにリクエスト送信 */
    if ( sprmib == E_Flag_OFF )
    {
      /* リクエスト送信 */
      ret = diagSendRequest( G_DiagnosticSessionControl_req_01 );
    }
    else if( sprmib == E_Flag_ON )
    {
      /* SPRMIBを設定するので、タイムアウト時に次のシーケンスに移れるよう専用のタイムアウトハンドラを再登録する */
      ret = diagSetTimeoutHandler(G_DiagnosticSessionControl_req_04, "DiagnosticSessionControl_timeout_handler");
      if(ret != 0)
      {
        /* ハンドラ設定失敗 */
        /* デバッグ表示 */
        Error_Log_output("DiagnosticSessionControl_request_01_send:diagSetTimeoutHandler error. for G_DiagnosticSessionControl_req_04");
      }
      /* リクエスト送信 */
      ret = diagSendRequest( G_DiagnosticSessionControl_req_04 );    
    }
    else
    {
      Error_Log_output("DiagnosticSessionControl_request_01_send: illegal sprmib set.");
    }
  }
  else if (addrtype == E_Send_Address_Func )
  {
    /* 機能アドレスにリクエスト送信 */
    if ( sprmib == E_Flag_OFF )
    {
      /* リクエスト送信 */
      ret = diagSendFunctional( G_DiagnosticSessionControl_req_01 );
    }
    else if( sprmib == E_Flag_ON )
    {
      /* SPRMIBを設定するので、タイムアウト時に次のシーケンスに移れるよう専用のタイムアウトハンドラを再登録する */
      ret = diagSetTimeoutHandler(G_DiagnosticSessionControl_req_04, "DiagnosticSessionControl_timeout_handler");
      if(ret != 0)
      {
        /* ハンドラ設定失敗 */
        /* デバッグ表示 */
        Error_Log_output("DiagnosticSessionControl_request_01_send:diagSetTimeoutHandler error. for G_DiagnosticSessionControl_req_04");
      }
      /* リクエスト送信 */
      ret = diagSendFunctional( G_DiagnosticSessionControl_req_04 );    
    }
    else
    {
      Error_Log_output("DiagnosticSessionControl_request_01_send: illegal sprmib set.");
    }
  }
  else
  {
    /* 通常ありえないがアドレス指定異常 */
    Error_Log_output("DiagnosticSessionControl_request_01_send:illegal addrtype.");
  }
  
  /* リクエスト送信の戻り値を返す */
  return ret;  
}


