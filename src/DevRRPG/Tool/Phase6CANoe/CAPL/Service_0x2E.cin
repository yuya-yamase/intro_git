  }
  else if( type == E_dataIdentifier_asfp_03 )
  {
    /* Fingerprintをリクエストオブジェクトに設定する */
    ret = WriteDataByIdentifier_set_Fingerprint( G_WriteDataByIdentifier_req_33 );
