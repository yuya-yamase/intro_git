/// <WriteDataByIdentifier>
/* ******************************************************** */
/* Function                                                 */
/*  WriteDataByIdentifier_req_distribution                  */
/* Discription                                              */
/*  Sid0x2E [WriteDataByIdentifier] request distribution    */
/* IN :                                                     */
/*  type   : dataIdentifierに相当する値                     */
/*  sprmib : SPRMIB有効フラグ(E_FLAG_ON=ならSPRMIBを付与)   */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSendRequest()の処理結果 または                      */
/*  E_Return_SPRMIB_Set_NG または E_Return_PRAMETER_NG      */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long WriteDataByIdentifier_req_distribution( dword type ,long sprmib )
{
  /* 戻り値 */
  int ret;
  
  /* dataIdentifierの指定によってリクエスト送信処理を振り分ける */
  if ( type == E_dataIdentifier_Nonce_00 )
  {
    /* Nonce値をリクエストオブジェクトに設定する */
    ret = WriteDataByIdentifier_set_Nonce( G_WriteDataByIdentifier_req_01 );
    if( ret == E_Return_OK )
    {
      /* リクエスト送信実施(Nonce) */
      ret = WriteDataByIdentifier_Nonce_request_01_send( sprmib, G_WriteDataByIdentifier_req_01 );
    }
  }
  else if( type == E_dataIdentifier_asfp_00 )
  {
    /* Fingerprintをリクエストオブジェクトに設定する */
    ret = WriteDataByIdentifier_set_Fingerprint( G_WriteDataByIdentifier_req_30 );
    if( ret == E_Return_OK )
    {
      /* リクエスト送信実施(Fingerprint) */
      ret = WriteDataByIdentifier_Fingerprint_request_01_send( sprmib, G_WriteDataByIdentifier_req_30 );
    }
  }
  else if( type == E_dataIdentifier_asfp_01 )
  {
    /* Fingerprintをリクエストオブジェクトに設定する */
    ret = WriteDataByIdentifier_set_Fingerprint( G_WriteDataByIdentifier_req_31 );
    if( ret == E_Return_OK )
    {
      /* リクエスト送信実施(Fingerprint) */
      ret = WriteDataByIdentifier_Fingerprint_request_01_send( sprmib, G_WriteDataByIdentifier_req_31 );
