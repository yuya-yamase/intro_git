/// <WriteDataByIdentifier>
/* ******************************************************** */
/* Function                                                 */
/*  WriteDataByIdentifier_res_distribution                  */
/* Discription                                              */
/*  Sid0x2E [WriteDataByIdentifier]  response distribution  */
/* IN :                                                     */
/*  res_msg   : diagResponse型のPosRspメッセージ            */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  E_Return_OK                                             */
/* NOTE:                                                    */
/*  byte#1 WriteDataByIdentifier Response SID               */
/*  byte#2 dataIdentifier #1                                */
/*  byte#2 dataIdentifier #2                                */
/* ******************************************************** */
long WriteDataByIdentifier_res_distribution( diagResponse * res_msg )
{
  /* 戻り値 */
  int ret;
  
   /* WriteDataByIdentifierのポジティブレスポンス受信時は処理無し */
  ret = E_Return_OK; 

  return ret;
}


/// <WriteDataByIdentifier>
/* *********************************************************************** */
/* Function                                                                */
/*  WriteDataByIdentifier_set_Nonce                                        */
/* Discription                                                             */
/*  設定済みのNonce値をWriteDataByIdentifierリクエストメッセージに設定する */
/* IN :                                                                    */
/*  req_msg   : diagRequest型のリクエストメッセージ                        */
/* OUT:                                                                    */
/*  None                                                                   */
/* RET:                                                                    */
/*  E_Return_OK                                                            */
/* NOTE:                                                                   */
/*  None                                                                   */
/* *********************************************************************** */
long WriteDataByIdentifier_set_Nonce( diagRequest * req_msg )
{
  /* 戻り値 */
  int ret;
  
  /* dataIdentifierの値を設定しておく領域 */
  byte dataIdentifier_buff[2];
  
  /* WriteDataByIdentifier_NonceのリクエストオブジェクトからdataIdentifier値を取得 */
  ret = diagGetParameterRaw(req_msg, "dataIdentifier",
                  dataIdentifier_buff,
                  elcount(dataIdentifier_buff)); 
  if( ret == E_Return_OK )
  {
      /* WriteDataByIdentifier_Nonceのリクエストオブジェクトに、 */
      /* 管理情報G_Reprog_General_DataのNonce値を設定 */
      ret = diagSetParameterRaw(req_msg, "Nonce",
             G_Reprog_General_Data.S_Info.nonce[G_Reprog_General_Data.S_Info.nonce_cnt],
             elcount(G_Reprog_General_Data.S_Info.nonce[G_Reprog_General_Data.S_Info.nonce_cnt]));
  }
  
  /* 戻り値の判断は上位関数で実施 */ 
  return ret;
}


/// <WriteDataByIdentifier>
/* ******************************************************************************** */
/* Function                                                                         */
/*  WriteDataByIdentifier_set_Fingerprint                                           */
/* Discription                                                                      */
/*  設定済みのFingerprintをWriteDataByIdentifierリクエストメッセージに設定する      */
/* IN :                                                                             */
/*  req_msg   : diagRequest型のリクエストメッセージ                                 */
/* OUT:                                                                             */
/*  None                                                                            */
/* RET:                                                                             */
/*  E_Return_OK                                                                     */
/* NOTE:                                                                            */
/*  None                                                                            */
/* ******************************************************************************** */
long WriteDataByIdentifier_set_Fingerprint( diagRequest * req_msg )
{
  /* 戻り値 */
  int ret;
  
  /* WriteDataByIdentifier_Nonceのリクエストオブジェクトに、 */
  /* 管理情報G_Reprog_General_DataのNonce値を設定 */
  ret = diagSetParameterRaw(req_msg, "applicationSoftwareFingerprint",
         G_Reprog_General_Data.S_Info.applicationSoftwareFingerprint[G_Reprog_General_Data.S_Info.asfp_cnt],
         elcount(G_Reprog_General_Data.S_Info.applicationSoftwareFingerprint[G_Reprog_General_Data.S_Info.asfp_cnt]));
  diagResize( req_msg, 3+G_Reprog_General_Data.S_Info.asfpsize[G_Reprog_General_Data.S_Info.asfp_cnt] );
  
  /* 戻り値の判断は上位関数で実施 */ 
  return ret;
}


/// <WriteDataByIdentifier>
/* ************************************************************************ */
/* Function                                                                 */
/*  WriteDataByIdentifier_init                                              */
/* Discription                                                              */
/*  外部設定情報ファイルを読み出してNonce値とテスターシリアル番号を設定する */
/* IN :                                                                     */
/*  filename : 外部設定情報ファイル名                                       */
/* OUT:                                                                     */
/*  None                                                                    */
/* RET:                                                                     */
/*  E_Return_OK                                                             */
/* NOTE:                                                                    */
/*  None                                                                    */
/* ************************************************************************ */
long WriteDataByIdentifier_init( char filename[] )
{
  /* 戻り値 */
  int ret;
  char read_nonce[(E_SecurityNonce_Byte*2)+2];
  char read_asfp[(E_Securityasfp_Byte*2)+2];
  char temp_filename[E_External_erase_file_name_size];
  char temp_buff[5];
  int cnt;
  int nonce_cnt;
  int asfp_cnt;
  int text_cnt;
  dword temp_handle;

  /* ファイル読み出し(Nonce) */
  ret = getProfileString( "Nonce", "Nonce", "Nonce.bin", temp_filename, elcount(temp_filename), filename );
  if( ret > 0 )
  {
    temp_handle = openFileRead( temp_filename, E_Openfile_mode_text );
    if( temp_handle > 0 )
    {
      /* Nonceの要素数＋１回ループ */
      /* 最初の1行は見出し行の為処理スキップする */
      for( nonce_cnt = 0; nonce_cnt < (E_TransferData_info_All_Element+1); nonce_cnt++)
      {
        ret = fileGetStringSZ( read_nonce, elcount(read_nonce), temp_handle );
        if( ret > 0 )
        {
          /* 最初の行のみ見出しなので読み捨て */
          if( nonce_cnt == 0)
          {
            continue;
          }
                
          /* 文字列をバイト配列に変換 */
          /* 2文字=1バイトとして変換していく */
          for( cnt = 0; cnt < E_SecurityNonce_Byte  ; cnt++ )
          {
            text_cnt = cnt * 2;
            temp_buff[0] = '0';
            temp_buff[1] = 'x';
            temp_buff[2] = read_nonce[text_cnt];
            temp_buff[3] = read_nonce[text_cnt+1];
        
            /* 読み出したNonce値を管理情報G_Reprog_General_Dataに設定 */
            G_Reprog_General_Data.S_Info.nonce[nonce_cnt-1][cnt] = atol(temp_buff);
          }
        }
        else
        {
          Error_Log_output("WriteDataByIdentifier_init: Nonce File Read Error.");
        }
      }
    }
    else
    {
      Error_Log_output("WriteDataByIdentifier_init: Nonce File Open Error.");
    }
  }
  else
  {
    Error_Log_output("WriteDataByIdentifier_init: Ext File Read Error.");
  }

  /* ファイル読み出し(applicationSoftwareFingerprint) */
  ret = getProfileString( "applicationSoftwareFingerprint", "applicationSoftwareFingerprint", "applicationSoftwareFingerprint.bin", temp_filename, elcount(temp_filename), filename );
  if( ret > 0 )
  {
    temp_handle = openFileRead( temp_filename, E_Openfile_mode_text );
    if( temp_handle > 0 )
    {
      /* applicationSoftwareFingerprintの要素数＋１回ループ */
      /* 最初の1行は見出し行の為処理スキップする */
      for( asfp_cnt = 0; asfp_cnt < (E_TransferData_info_All_Element+1); asfp_cnt++)
      {
        ret = fileGetStringSZ( read_asfp, elcount(read_asfp), temp_handle );
        if( ret > 0 )
        {
          /* 最初の行のみ見出しなので読み捨て */
          if( asfp_cnt == 0)
          {
            continue;
          }
          
          /* applicationSoftwareFingerprintサイズを取得する */
          G_Reprog_General_Data.S_Info.asfpsize[asfp_cnt-1] = strlen(read_asfp)/2;
          
          /* 文字列をバイト配列に変換 */
          /* 2文字=1バイトとして変換していく */
          for( cnt = 0; cnt < E_Securityasfp_Byte  ; cnt++ )
          {
            text_cnt = cnt * 2;
            temp_buff[0] = '0';
            temp_buff[1] = 'x';
            temp_buff[2] = read_asfp[text_cnt];
            temp_buff[3] = read_asfp[text_cnt+1];
            
            /* 読み出したapplicationSoftwareFingerprint値を管理情報G_Reprog_General_Dataに設定 */
            G_Reprog_General_Data.S_Info.applicationSoftwareFingerprint[asfp_cnt-1][cnt] = atol(temp_buff);
          }
        }
        else
        {
          Error_Log_output("WriteDataByIdentifier_init: applicationSoftwareFingerprint File Read Error.");
        }
      }
    }
    else
    {
      Error_Log_output("WriteDataByIdentifier_init: applicationSoftwareFingerprint File Open Error.");
    }
  }
  else
  {
    Error_Log_output("WriteDataByIdentifier_init: Ext File Read Error.");
  }

  return ret;
}

