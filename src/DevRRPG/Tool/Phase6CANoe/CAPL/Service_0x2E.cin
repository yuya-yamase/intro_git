/// <WriteDataByIdentifier>
/* ******************************************************* */
/* Function                                                */
/*  WriteDataByIdentifier_Nonce_request_01_send            */
/* Discription                                             */
/*  Send Request Sid0x2E [WriteDataByIdentifier]           */
/* IN :                                                    */
/*  sprmib : SPRMIB有効フラグ(E_FLAG_ON=ならSPRMIBを付与)  */
/*  req_msg   : diagRequest型のリクエストメッセージ        */
/* OUT:                                                    */
/*  None                                                   */
/* RET:                                                    */
/*  diagSendRequest()の処理結果 または                     */
/*  E_Return_SPRMIB_Set_NG                                 */
/* NOTE:                                                   */
/*  None                                                   */
/* ******************************************************* */
long WriteDataByIdentifier_Nonce_request_01_send( long sprmib, diagRequest * req_msg )
{
  /* 戻り値 */
  int ret;

  /* リクエスト送信 */  
  ret = diagSendRequest(req_msg);

  /* リクエスト送信の戻り値を返す */
  return ret;
}


