      break;
    }

    /* SID 0x2E WriteDataByIdentifier用定義 */
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_01");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_30, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_30");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_31, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_31");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_32, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_32");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_33, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_33");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_34, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_34");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_35, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_35");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_36, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_36");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_37, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_37");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_38, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_38");
      break;
    }
    ret = diagSetTimeoutHandler(G_WriteDataByIdentifier_req_39, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_WriteDataByIdentifier_req_39");
      break;
    }



    /* SID 0x31 RoutineControl用定義 */
    ret = diagSetTimeoutHandler(G_RoutineControl_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_RoutineControl_req_01");
      break;
    }
    ret = diagSetTimeoutHandler(G_RoutineControl_req_02, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_RoutineControl_req_02");
      break;
    }
    ret = diagSetTimeoutHandler(G_RoutineControl_req_03, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_RoutineControl_req_03");
      break;
    }
    ret = diagSetTimeoutHandler(G_RoutineControl_req_04, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_RoutineControl_req_04");
      break;
    }


    /* SID 0x34 RequestDownload用定義 */
    ret = diagSetTimeoutHandler(G_RequestDownload_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_RequestDownload_req_01");
      break;
    }

    /* SID 0x36 TransferData用定義 */
    ret = diagSetTimeoutHandler(G_TransferData_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_TransferData_req_01");
      break;
    }

    /* SID 0x37 RequestTransferExit用定義 */
    ret = diagSetTimeoutHandler(G_RequestTransferExit_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_RequestTransferExit_req_01");
      break;
    }

    /* SID 0x38 TesterPresent用定義 */
    /* TesterPresentは独立周期的なリクエストなのでハンドラは不要 */

  }
  while(0);

  return ret;
}


/// <General>
/* **************************************************** */
/* Function                                             */
/*  Control_transportlayer_setup                        */
/* Discription                                          */
/*  診断記述ファイルの定義に従ってTP層の設定            */
/* IN :                                                 */
/*  diag_def_name : 診断記述ファイルのECU修飾子         */
/* OUT:                                                 */
/*  None                                                */
/* RET:                                                 */
/*  diagSetTarget()の処理結果                           */
/* NOTE:                                                */
/*  None                                                */
/* **************************************************** */
int Control_transportlayer_setup(char diag_def_name[])
{
  /* 戻り値 */
  int ret;

  /* 診断記述ファイルから、対象となる制御デバイスの選択し初期設定を行う */
  ret = diagSetTarget(diag_def_name);

  /* diagSetTarget()の戻り値を返す */
  return ret;
}


/// <General>
/* *********************************************************** */
/* Function                                                    */
/*  Request_sender                                             */
/* Discription                                                 */
/*  CANoeシーケンスに対応するリクエスト送信関数の選定          */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  デバッグしやすくする為variable_initialize()による初期化後  */
/*   かつ　CANoeシナリオ自動実行中のみ処理が有効になる         */
/* *********************************************************** */
void Request_sender(void)
{
  /* 戻り値 */
  int ret;
  char errolog_buff[128];

  /* 初期化済み かつ 自動実行の有効フラグがON場合のみ次シーケンスの動作を起動する */
  if (G_Reprog_General_Data.G_Info.initialze == E_Flag_ON &&
      G_Reprog_General_Data.G_Info.enable_autorun == E_Flag_ON )
  {
    /* シーケンス位置によって送信するリクエストを特定 */
    /* (switch文は使わない方が良さそうなのでif～elseif～elseで実現)  */
    if (  G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x22_hwi_req )
    {
      /* リクエスト送信(ReadDataByIdentifier) */
      ret = ReadDataByIdentifier_req_distribution( E_dataIdentifier_HWIdentification, E_Flag_OFF );
      if ( ret == E_Return_OK )
      {
        /* リクエスト送信成功 */
        /* シーケンス位置を更新し、「レスポンス受信」か「タイムアウト検出」まで待機 */
