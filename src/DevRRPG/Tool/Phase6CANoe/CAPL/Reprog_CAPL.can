/// <General>
/* ******************************************************** */
/* Function                                                 */
/*  Response_Receiver                                       */
/* Discription                                              */
/*  ポジティブレスポンス受信時の処理                        */
/* IN :                                                     */
/*  res_msg : diagResponse型の受信メッセージ                */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  TBD                                                     */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
int Response_Receiver( diagResponse *res_msg )
{
  /* 戻り値 */
  int ret;

  /* 現在のシーケンス位置を判定し、そのシーケンス位置で行うべき処理に振り分け */
  if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x22_hwi_posres )
  {
    /* SID 0x22 ReadDataByIdentifier(HWIdentification) ポジティブレスポンス受信完了 */
    ret = ReadDataByIdentifier_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x22_hwi_posres.");
    }
    {
      ret = Authentication_req_distribution( E_authenticationTask_authenticationConfiguration, E_Flag_OFF );
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x22_swi_posres )
  {
    /* SID 0x22 ReadDataByIdentifier(HWIdentification) ポジティブレスポンス受信完了 */
    ret = ReadDataByIdentifier_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x22_swi_posres.");
    }
  }
  else if( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_ext_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(extendedDiagnosticSession) ポジティブレスポンス受信完了 */
    ret = DiagnosticSessionControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x10_ext_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x28_rxtx_posres )
  {
    /* SID 0x28 CommunicationControl(disableRxAndTx) ポジティブレスポンス受信完了 */
    ret = CommunicationControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x28_rxtx_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_prog_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(ProgrammingSession) ポジティブレスポンス受信完了 */
    ret = DiagnosticSessionControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x10_prog_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x27_seed_posres )
  {
    /* SID 0x27 SecurityAccess(requestSeed) ポジティブレスポンス受信完了 */
    ret = SecurityAccess_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x27_seed_posres.");
    }
    else
    {
      /* シード値を保存する */
      SecurityAccess_Set_Seed(res_msg, E_SecuritySeed_Byte);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x27_key_posres )
  {
    /* SID 0x27 SecurityAccess(sendKey) ポジティブレスポンス受信完了 */
    ret = SecurityAccess_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x27_key_posres.");
    }

    /* SID 0x27 SecurityAccess[sendKey]のレスポンス受信直後の時間測定 */
    G_Timespec_Array[E_Timespec_Seqence_SeedKey_0x27_End] = timeNowInt64();
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x2E_nonce_posres )
  {
    /* SID 0x2E WriteDataByIdentifier(Nonce) ポジティブレスポンス受信完了 */
    ret = WriteDataByIdentifier_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x2E_nonce_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x2E_asfp_posres )
  {
    /* SID 0x2E WriteDataByIdentifier(applicationSoftwareFingerprint) ポジティブレスポンス受信完了 */
    ret = WriteDataByIdentifier_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x2E_asfp_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x34_SBL_posres )
  {
    /* SID 0x34 RequestDownload(消去・書込みルーチン) ポジティブレスポンス受信完了 */
    ret = RequestDownload_res_distribution( G_Reprog_General_Data.T_Info_Erase.transfer_size, res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x34_SBL_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x36_dl_SBL_posres )
  {
    /* SID 0x36 TransferData(ダウンロード) ポジティブレスポンス受信完了 */
    ret = TransferData_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x36_dl_SBL_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x37_SBL_posres )
  {
    /* SID 0x37 RequestTransferExit(消去・書込みルーチン) ポジティブレスポンス受信完了 */
    ret = RequestTransferExit_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x37_SBL_posres.");
    }

    /* 消去ルーチンに対するSID 0x37 RequestTransferExitのレスポンス受信直後の時間測定 */
    G_Timespec_Array[E_Timespec_Seqence_erase_0x37_End] = timeNowInt64();
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_signature_posres )
  {
    /* SID 0x31 RoutineControl(checkMemoryFlashdriver) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_check_mfd_signature_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_cmac_posres )
  {
    /* SID 0x31 RoutineControl(checkMemoryFlashdriver) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_check_mfd_cmac_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_crc_posres )
  {
    /* SID 0x31 RoutineControl(checkMemoryFlashdriver) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_check_mfd_crc_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_erase_posres )
  {
    /* SID 0x31 RoutineControl(eraseMemory) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_erase_posres.");
    }
    /* SID 0x31 RoutineControl(eraseMemory)のレスポンス受信直後の時間測定 */
    G_Timespec_Array[E_Timespec_Seqence_erasemem_0x31_End] = timeNowInt64();
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x34_APL_posres )
  {
    /* SID 0x34 RequestDownload(書換えデータ) ポジティブレスポンス受信完了 */
    ret = RequestDownload_res_distribution( G_Reprog_General_Data.T_Info_Reprog.transfer_size, res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x34_APL_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x36_dl_APL_posres )
  {
    /* SID 0x36 TransferData(ダウンロード) ポジティブレスポンス受信完了 */
    ret = TransferData_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x36_dl_APL_posres.");
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x37_APL_posres )
  {
    /* SID 0x37 RequestTransferExit(書換えデータ) ポジティブレスポンス受信完了 */
    ret = RequestTransferExit_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x37_APL_posres.");
    }

    /* 書込みファイルに対するSID 0x37 RequestTransferExitのレスポンス受信直後の時間測定 */
    G_Timespec_Array[E_Timespec_Seqence_Apl_0x37_End] = timeNowInt64();
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_signature_posres )
  {
    /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_check_msd_signature_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_cmac_posres )
  {
    /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_check_msd_cmac_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_crc_posres )
  {
    /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_check_msd_crc_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_valid_posres )
  {
    /* SID 0x31 RoutineControl(validApplication) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_valid_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_valid_sig_posres )
  {
    /* SID 0x31 RoutineControl(validApplication) ポジティブレスポンス受信完了 */
    ret = RoutineControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x31_valid_sig_posres.");
      CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x11_ECUReset_posres )
  {
    /* SID 0x11 ECUReset ポジティブレスポンス受信完了 */
    ret = ECUReset_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x11_ECUReset_posres.");
    }

    /* CANoeシナリオの終了直後の時間測定 */
    /* CANoeシナリオの最後のシーケンスはSID 0x10かSID 0x11なので両方に処理を追加 */
    G_Timespec_Array[E_Timespec_Seqence_End] = timeNowInt64();
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_def_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(defaultSession) ポジティブレスポンス受信完了 */
    ret = DiagnosticSessionControl_res_distribution(res_msg);
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_Receiver: Response Error. E_PP1_SID_0x10_def_posres.");
    }

    /* CANoeシナリオの終了直後の時間測定 */
    /* CANoeシナリオの最後のシーケンスはSID 0x10かSID 0x11なので両方に処理を追加 */
    G_Timespec_Array[E_Timespec_Seqence_End] = timeNowInt64();
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_Seqence_Normal_End )
  {
    /* CANoeシナリオ正常終了後に謎のポジティブレスポンス受信 */
    Debug_Log_output("Response_Receiver: Unknown Response.");
  }
  else
  {
    /* CANoe_Seqence_Direct_Updateで変な値にしていない限りエラーは発生しない */
    Error_Log_output("Response_Receiver: Response Error. Illegal Seqnece.");
    write("%d",G_Reprog_General_Data.G_Info.pp1_process);
  }

  return ret;
}


/// <General>
/* ******************************************************** */
/* Function                                                 */
/*  Response_After_Receiver                                 */
/* Discription                                              */
/*  ポジティブレスポンス受信時のサービス固有処理の選定      */
/* IN :                                                     */
/*  before_seqence: 更新前のシーケンス位置                  */
/*  res_msg : diagResponse型の受信メッセージ                */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSendRequest()の処理結果 または                      */
/*  E_Return_OK                                             */
/* NOTE:                                                    */
/*  処理ループの為のシーケンス位置の制御等はここで実施      */
/* ******************************************************** */
int Response_After_Receiver( int before_seqence, diagResponse *res_msg )
{
  /* 戻り値 */
  int ret;
  int skipflg;
  dword read_size;  /* 読み出したバッファサイズを格納 */

  /*　初期値を設定 */
  ret = E_Return_OK;
  skipflg = E_Flag_OFF;

  /* 更新前のシーケンス位置を判定し、そのシーケンス位置で行うべき処理に振り分け */
  if ( before_seqence == E_PP1_SID_0x27_seed_posres )
  {
    /* SID 0x27 SecurityAccess(requestSeed) ポジティブレスポンス受信完了 */
    /* シード値からキー値を生成する */

    /* SecurityAccess_Generate_Keyで使用するパラメータを生成 */
    SecurityAccess_Set_Generate_Key_Pram(res_msg);

    /* DLLを使ってシード値からキー値を生成 */
    ret = SecurityAccess_Generate_Key(G_Reprog_General_Data.S_Info.securityseed,
                                      G_Reprog_General_Data.S_Info.seedArraySize,
                                      G_Reprog_General_Data.S_Info.securityLevel,
                                      G_Reprog_General_Data.S_Info.variant,
                                      G_Reprog_General_Data.S_Info.ipOption,
                                      G_Reprog_General_Data.S_Info.maxKeyArraySize,
                                      G_Reprog_General_Data.S_Info.securitykey,
                                      G_Reprog_General_Data.S_Info.keyActualSize );
    if( ret != E_Return_OK )
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x27_seed_req.");
    }
  }
  else if ( before_seqence == E_PP1_SID_0x2E_nonce_posres )
  {
    /* SID　0x2E WriteDataByIdentifier(Nonce) ポジティブレスポンス受信完了 */
  }
  else if ( before_seqence == E_PP1_SID_0x2E_asfp_posres )
  {
    /* SID　0x2E WriteDataByIdentifier(applicationSoftwareFingerprint) ポジティブレスポンス受信完了 */
    /* applicationSoftwareFingerprintのカウンタをカウントアップする */
    G_Reprog_General_Data.S_Info.asfp_cnt = (G_Reprog_General_Data.S_Info.asfp_cnt + 1);
    G_Reprog_General_Data.G_Info.check_count = 0;

    /* 後続の処理の為、RequestDownload,　TransferDataに関連する情報をマスターファイルから作業領域にコピー */
    memcpy(G_Reprog_General_Data.T_Info_Erase, G_TransferData_Info_Erase[G_Reprog_General_Data.G_Info.multiple_file_count]);
    memcpy(G_Reprog_General_Data.T_Info_Reprog, G_TransferData_Info_Reprog[G_Reprog_General_Data.G_Info.multiple_file_count]);
  }
  else if ( before_seqence == E_PP1_SID_0x34_SBL_posres )
  {
    /* 消去書込みルーチンを事前にオープンしておく */
    ret = TransferData_open_file(G_Reprog_General_Data.T_Info_Erase.filename,
                                 E_Openfile_mode_binary, G_Reprog_General_Data.T_Info_Erase.filehandle );

    if( ret == E_Return_OK )
    {
      /* 初回の読み出しはこのタイミングで実施しておく */
      ret = TransferData_read_file( G_Reprog_General_Data.T_Info_Erase.filehandle,
                                    G_Reprog_General_Data.T_Info_Erase.transfer_size,
                                    G_Reprog_General_Data.transferdata_readbuff,
                                    read_size );
      if( ret == E_Return_OK )
      {
        /* 読み出したバッファサイズを加算 */
        G_Reprog_General_Data.T_Info_Erase.size_all = G_Reprog_General_Data.T_Info_Erase.size_all + read_size;
        /* 常時読みだしたサイズを送信する */
        G_Reprog_General_Data.T_Info_Erase.transfer_size = read_size;
      }
      else
      {
        /* エラーの場合はどうすればいいんだろうね？ */
        Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x34_SBL_req(read).");
      }

    }
    else
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x34_SBL_req(open).");
    }
  }
  else if ( before_seqence == E_PP1_SID_0x36_dl_SBL_posres )
  {
    /* SID 0x36 TransferData(ダウンロード) ポジティブレスポンス受信完了 */
    /* 消去・書込みルーチンの転送回数をカウントアップ */
    /* 1回目のblockSequenceCounterは0x01だが、256回目のblockSequenceCounterは0x00なので、桁あふれの対処はしない */
    G_Reprog_General_Data.T_Info_Erase.cnt[0] = ( G_Reprog_General_Data.T_Info_Erase.cnt[0] + 1 );

    /* 次の読み出しはこのタイミングで実施しておく */
    ret = TransferData_read_file( G_Reprog_General_Data.T_Info_Erase.filehandle,
                                  G_Reprog_General_Data.T_Info_Erase.transfer_size,
                                  G_Reprog_General_Data.transferdata_readbuff,
                                  read_size );

    /* 転送データがまだ存在するかどうかを判定し、転送データがまだ残っている場合は再度SID 0x36 TransferData(ダウンロード)送信を実行 */
    if( ret == E_Return_OK )
    {
      /* 読み出したバッファサイズを加算 */
      G_Reprog_General_Data.T_Info_Erase.size_all = G_Reprog_General_Data.T_Info_Erase.size_all + read_size;
      /* 常時読みだしたサイズを送信する */
      G_Reprog_General_Data.T_Info_Erase.transfer_size = read_size;

      /* 転送データがまだある場合はシーケンス位置を強制的に「SID 0x36 TransferData(ダウンロード) 送信」に変更してループさせる */
      CANoe_Seqence_Direct_Update(E_PP1_SID_0x36_dl_SBL_req);
    }
    else if( ret == E_Return_EOF )
    {
      /* シーケンス位置の再設定を行わずに、次のシーケンスへ進む */
      /* 消去書込みルーチンのクローズ処理 */
      ret = TransferData_close_file(G_Reprog_General_Data.T_Info_Erase.filehandle);
      if( ret != E_Return_OK )
      {
        /* エラーの場合はどうすればいいんだろうね？ */
        Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x36_dl_SBL_req(Close).");
      }
    }
    else
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x36_dl_SBL_req(Read).");
    }
  }
  else if ( before_seqence == E_PP1_SID_0x34_APL_posres )
  {
    /* 書込みデータを事前にオープンしておく */
    ret = TransferData_open_file(G_Reprog_General_Data.T_Info_Reprog.filename, E_Openfile_mode_binary,
                     G_Reprog_General_Data.T_Info_Reprog.filehandle );
    if( ret == E_Return_OK )
    {
      /* 初回の読み出しはこのタイミングで実施しておく */
      ret = TransferData_read_file( G_Reprog_General_Data.T_Info_Reprog.filehandle,
                                    G_Reprog_General_Data.T_Info_Reprog.transfer_size,
                                    G_Reprog_General_Data.transferdata_readbuff,
                                    read_size );
      if( ret == E_Return_OK )
      {
        /* 読み出したバッファサイズを加算 */
        G_Reprog_General_Data.T_Info_Reprog.size_all = G_Reprog_General_Data.T_Info_Reprog.size_all + read_size;
        /* 常時読みだしたサイズを送信する */
        G_Reprog_General_Data.T_Info_Reprog.transfer_size = read_size;

      }
      else
      {
        /* エラーの場合はどうすればいいんだろうね？ */
        Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x34_APL_req(Close).");
      }
    }
    else
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x34_APL_req(Read).");
    }
  }
  else if ( before_seqence == E_PP1_SID_0x36_dl_APL_posres )
  {
    /* SID 0x36 TransferData(ダウンロード) ポジティブレスポンス受信完了 */
    /* 書込みデータの転送回数をカウントアップ */
    /* 1回目のblockSequenceCounterは0x01だが、256回目のblockSequenceCounterは0x00なので、桁あふれの対処はしない */
    G_Reprog_General_Data.T_Info_Reprog.cnt[0] = ( G_Reprog_General_Data.T_Info_Reprog.cnt[0] + 1 );

    /* 次の読み出しはこのタイミングで実施しておく */
    ret = TransferData_read_file( G_Reprog_General_Data.T_Info_Reprog.filehandle,
                                  G_Reprog_General_Data.T_Info_Reprog.transfer_size,
                                  G_Reprog_General_Data.transferdata_readbuff,
                                  read_size );

    /* 転送データがまだ存在するかどうかを判定し、転送データがまだ残っている場合は再度SID 0x36 TransferData(ダウンロード)送信を実行 */
    if( ret == E_Return_OK )
    {
      /* 読み出したバッファサイズを加算 */
      G_Reprog_General_Data.T_Info_Reprog.size_all = G_Reprog_General_Data.T_Info_Reprog.size_all + read_size;
      /* 常時読みだしたサイズを送信する */
      G_Reprog_General_Data.T_Info_Reprog.transfer_size = read_size;

      /* 転送データがまだある場合はシーケンス位置を強制的に「SID 0x36 TransferData(ダウンロード) 送信」に変更してループさせる */
      CANoe_Seqence_Direct_Update(E_PP1_SID_0x36_dl_APL_req);
    }
    else if( ret == E_Return_EOF )
    {
      /* シーケンス位置の再設定を行わずに、次のシーケンスへ進む */
      /* 書込みデータのクローズ処理 */
      ret = TransferData_close_file(G_Reprog_General_Data.T_Info_Reprog.filehandle);
      if( ret != E_Return_OK )
      {
        /* エラーの場合はどうすればいいんだろうね？ */
        Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x36_dl_APL_req(Close).");
      }
    }
    else
    {
      /* エラーの場合はどうすればいいんだろうね？ */
      Error_Log_output("Response_After_Receiver: Response Error. E_PP1_SID_0x36_dl_APL_req(Read).");
    }
  }
  else if ( before_seqence == E_PP1_SID_0x31_check_msd_signature_posres  ||
            before_seqence == E_PP1_SID_0x31_check_msd_cmac_posres ||
            before_seqence == E_PP1_SID_0x31_check_msd_crc_posres)
  {
    if ( G_Reprog_General_Data.G_Info.check_count == 0 )
    {
      /* 1連の消去～書き換えの処理が完了したので、書換え対象領域の何回目を実施しているかのカウンタを更新 */
      G_Reprog_General_Data.G_Info.multiple_file_count = G_Reprog_General_Data.G_Info.multiple_file_count + 1;
      G_Reprog_General_Data.G_Info.check_count = G_Reprog_General_Data.G_Info.check_count + 1;

      /* 書換え対象領域の総数分の消去～書き換えの処理を実施したかどうか判定 */
      if( G_Reprog_General_Data.G_Info.multiple_file_count < G_Reprog_General_Data.G_Info.multiple_file_num)
      {
        /* 書換え対象領域の総数分の処理を実施していない場合はシーケンス位置を強制的に「SID 0x2E WriteDataByIdentifier(Nonce) 送信」に変更してループさせる */
        CANoe_Seqence_Direct_Update(E_PP1_SID_0x2E_asfp_req);
      }
    }
  }
  else if ( before_seqence == E_PP1_SID_0x31_valid_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(defaultSession) 送信を使用する指定か判定 */
    if( G_Reprog_General_Data.R_Info.reset_service == E_Reset_Service_0x10_ds )
    {
      /* シーケンス位置を強制的に「SID 0x10 DiagnosticSessionControl(defaultSession) 送信」に変更する */
      CANoe_Seqence_Direct_Update(E_PP1_SID_0x10_def_req);
    }
  }
 else if ( before_seqence == E_PP1_SID_0x31_valid_sig_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(defaultSession) 送信を使用する指定か判定 */
    if( G_Reprog_General_Data.R_Info.reset_service == E_Reset_Service_0x10_ds )
    {
      /* シーケンス位置を強制的に「SID 0x10 DiagnosticSessionControl(defaultSession) 送信」に変更する */
      CANoe_Seqence_Direct_Update(E_PP1_SID_0x10_def_req);
    }
  }
  else if ( before_seqence == E_PP1_SID_0x11_ECUReset_posres )
  {
    /* SID 0x11 EcuResetとSID 0x10 DiagnosticSessionControl(defaultSession)はどちらかを実行すれば良いので、 */
    /* SID 0x11 EcuResetの次のシーケンスは、SID 0x10 DiagnosticSessionControl(defaultSession)の次のシーケンスと同じ */
    CANoe_Seqence_Direct_Update(E_PP1_Seqence_Normal_End);
  }
  else
  {
    /* 事後処理が必要でないシーケンスはここを通る */
  }

  return ret;
}


/// <General>
/* ************************************************************************  */
/* Function                                                                  */
/*  Diag_Response_handler                                                    */
/* Discription                                                               */
/*  診断機能のレスポンス受信時の受信ハンドラ                                 */
/* IN :                                                                      */
/*  res_msg : diagResponse型の受信メッセージ                                 */
/* OUT:                                                                      */
/*  None                                                                     */
/* RET:                                                                      */
/*  None                                                                     */
/* NOTE:                                                                     */
/*  「on diagResponse」と特定のメッセージのタイムアウトハンドラから呼ばれる  */
/* ************************************************************************* */

void Diag_Response_handler(diagResponse *res_msg)
{
  int before_seqence;
  long first_byte;
  long second_byte;
  long third_byte;

  /* 「初期化済み」かどうかを判定 */
  /* 「初期化済み」でない場合は特に何もせず受信データを読み捨て */
  if (G_Reprog_General_Data.G_Info.initialze == E_Flag_ON )
  {
    /* 初期化済み かつ 自動実行の有効フラグがONの場合は次シーケンスの動作を起動する */
    /* 初期化済み かつ 自動実行の有効フラグがON かつ APL起動要求の有効フラグがONの場合も同様の処理を行う */
    if( G_Reprog_General_Data.G_Info.enable_autorun == E_Flag_ON )
    {
      /* 受信したレポンスがポジティブレスポンスかネガティブレスポンスかを判定する */
      if (res_msg.IsPositiveResponse() == 1)
      {
        /* 受信データがSID 0x10 (ProgrammingSession)のポジティブレスポンスであるか判定 */
        /* SID 0x10 (ProgrammingSession)のポジティブレスポンスは、0バイト目が'0x50'で1バイト目が'0x02' */
        /* 0バイト目を読み出し(エラーチェックはこの後の読み出し値のチェックで代用するので不要)*/
        first_byte = diagGetPrimitiveByte( res_msg, 0);
        /* 1バイト目を読み出し(エラーチェックはこの後の読み出し値のチェックで代用するので不要)*/
        /* TBD：SID 0x37の受信時にCANoeのウィンドウにwarningが出るので(実害は無いが)なんとかしたい */
        second_byte = diagGetPrimitiveByte( res_msg, 1);

        /* SID 0x10 (ProgrammingSession)のポジティブレスポンスであるか判定 */
        /* このルートでは既にCANoeシナリオ実行中であり、APL要求起動のメッセージは無視したい */
        if( first_byte != 0x50 || second_byte != 0x02 ||
             G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_prog_posres)
        {
          /* ポジティブレスポンス受信ルート */
          /* デバッグ表示(性能に影響するのでデバッグ時のみ有効にすること) */
          /* Debug_Log_output("Positive response received."); */

          /* ポジティブレスポンス受信処理を実施 */
          Response_Receiver( res_msg );

          /* 追加処理の為、更新前のシーケンス位置を記録しておく */
          before_seqence = CANoe_Seqence_Get();

          /* ポジティブレスポンスであれば次のシーケンスに移行する */
          CANoe_Seqence_Response_Update();

          /* 追加で処理が必要なサービスはここで処理を実施する */
          /* (処理ループの為のシーケンス位置の制御等)*/
          Response_After_Receiver( before_seqence , res_msg );

          /* CANoeシナリオの停止機能の対象となっている場合はCANoeシナリオを停止する設定 */
          CANoe_Seqence_Stop_Check();

          /* Phase6 の場合はSID 0x27(Seed) 前に、Wait 入れる */
          if( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x27_seed_req )
          {
            setTimer(TwaitTimer, 1 * 1000); // 1 秒待ち
          }
          else
          {
            /* 次のリクエストの送信を実施 */
            Request_sender();
          }
        }
      }
      else
      {
        /* ネガティブレスポンス受信ルート */
        second_byte = diagGetPrimitiveByte( res_msg, 1);
        third_byte = diagGetPrimitiveByte( res_msg, 2);
        if( second_byte == 0x29 && third_byte == 0x11 )
        {
          /* SID 0x29 がネガティブレスポンスでもシーケンス継続 */
          CANoe_Seqence_Direct_Update(E_PP1_SID_0x10_ext_req);

          /* CANoeシナリオの停止機能の対象となっている場合はCANoeシナリオを停止する設定 */
          CANoe_Seqence_Stop_Check();

          /* 次のリクエストの送信を実施 */
          Request_sender();
        }
        else
        {
          /* デバッグ表示 */
          Debug_Log_output("Negative response received.");
        }
      }
    }
    else
    {
      /* 「初期化済み かつ 自動実行の有効フラグがON」でない */
      /* このような場合は特に何もせず受信データを読み捨て */

      /* デバッグ表示(性能に影響するのでデバッグ時のみ有効にすること) */
      /* Debug_Log_output("Not Initialize. Discard Receive Data"); */
    }
  }

  return;
}

/// <General>
/* ******************************************************** */
/* Function                                                 */
/*  Debug_Log_output                                        */
/* Discription                                              */
/*  ログメッセージをデバッグログに出力する                  */
/* IN :                                                     */
/*  logmsg : 出力するログメッセージ                         */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  None                                                    */
/* NOTE:                                                    */
/*  ログメッセージは先頭に"DEBUG：”を付与して出力する      */
/*  ログメッセージは1行辺り120文字までとする                */
/* ******************************************************** */
void Debug_Log_output( char logmsg[] )
{
  long retval;                /* 戻り値 */
  char debug_log_msg[E_Debug_log_buffer_size];    /* ログメッセージバッファ */

  /* 文字列長チェック */
  if( strlen(logmsg) > (E_Debug_log_buffer_size - 8) )
  {
    /* 文字列長がE_Debug_log_buffer_size - 8文字(固定の文字列分)以上の場合はエラー終了 */
    return;
  }

  /* 書込むメッセージを生成 */
  retval = snprintf(debug_log_msg,  elcount(debug_log_msg), "DEBUG: %s\n", logmsg );
  if( retval > 0 && retval <= E_Debug_log_buffer_size )
  {
    /* メッセージ生成成功 */
    /* 生成したメッセージをログファイルに書き込み */
    filePutString (debug_log_msg, elcount(debug_log_msg), G_debug_log_file_handle);
  }
  else
  {
    /* メッセージ生成失敗 */
    /* メッセージ生成失敗時は出力windowへ出力 */
    write ("%s", logmsg);
  }

  return;
}


/// <General>
/* ******************************************************** */
/* Function                                                 */
/*  Error_Log_output                                        */
/* Discription                                              */
/*  エラーメッセージをデバッグログに出力する                */
/* IN :                                                     */
/*  logmsg : 出力するエラーメッセージ                       */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  None                                                    */
/* NOTE:                                                    */
/*  エラーメッセージは先頭に"ERROR：”を付与して出力する    */
/*  ログメッセージは1行辺り120文字までとする                */
/* ******************************************************** */
void Error_Log_output( char logmsg[] )
{
  long retval;                /* 戻り値 */
  char error_log_msg[E_Debug_log_buffer_size];    /* ログメッセージバッファ */

  /* 文字列長チェック */
  if( strlen(logmsg) > (E_Debug_log_buffer_size - 8) )
  {
    /* 文字列長がE_Debug_log_buffer_size - 8文字(固定の文字列分)以上の場合はエラー終了 */
    return;
  }

  /* 書込むメッセージを生成 */
  retval = snprintf(error_log_msg,  elcount(error_log_msg), "ERROR: %s\n", logmsg );
  if( retval > 0 && retval <= E_Debug_log_buffer_size )
  {
    /* メッセージ生成成功 */
    /* 生成したメッセージをログファイルに書き込み */
    filePutString (error_log_msg, elcount(error_log_msg), G_debug_log_file_handle);
  }
  else
  {
    /* メッセージ生成失敗 */
    /* メッセージ生成失敗時は出力windowへ出力 */
    write ("%s", logmsg);
  }

  return;
}



/// <General>
/* ******************************************************** */
/* Function                                                 */
/*  Timespec_Log_output                                     */
/* Discription                                              */
/*  時間測定結果をデバッグログに出力する                    */
/* IN :                                                     */
/*  None                                                    */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  None                                                    */
/* NOTE:                                                    */
/*  時間測定メッセージは先頭に"TIME：”を付与して出力する   */
/*  ログメッセージは1行辺り120文字までとする                */
/* ******************************************************** */
void Timespec_Log_output(void)
{
  long retval;                /* 戻り値 */
  int cnt;
  char time_log_msg[E_Debug_log_buffer_size];    /* ログメッセージバッファ */

  /* 時間測定の全測定箇所のログ出力を行うまでループ */
  for( cnt = 0; cnt < E_Timespec_Seqence_MAX; cnt++ )
  {
    /* 書込むメッセージを生成 */
    retval = snprintf(time_log_msg,  elcount(time_log_msg), "TIME: timespec[%d]=%lld(nanosecond)\n", cnt, G_Timespec_Array[cnt] );
    if( retval > 0 && retval <= E_Debug_log_buffer_size )
    {
      /* メッセージ生成成功 */
      /* 生成したメッセージをログファイルに書き込み */
      filePutString (time_log_msg, elcount(time_log_msg), G_debug_log_file_handle);
    }
    else
    {
      /* メッセージ生成失敗 */
      /* メッセージ生成失敗時は出力windowへ出力 */
      write ("%s", time_log_msg);
    }
  }

  return;
}


/// <General>
/* **************************************************************************** */
/* Function                                                                     */
/*  TransferData_Setting                                                        */
/* Discription                                                                  */
/*  転送データに関する各種設定情報を、管理領域に設定する処理                    */
/* IN :                                                                         */
/*  type         : E_RoutineControl_Type_Numに相当する値                        */
/*  filename     : 転送データに関する設定情報を記述したファイル名を格納する領域 */
/*  ext_filename : 外部設定情報ファイル名                                       */
/* OUT:                                                                         */
/*  filename : 転送データに関する設定情報を記述したファイル名                   */
/* RET:                                                                         */
/*  None                                                                        */
/* NOTE:                                                                        */
/*  None                                                                        */
/* **************************************************************************** */
int TransferData_Setting_Filename( int type, char filename[], char ext_filename[] )
{
  /* 戻り値 */
  long pos;
  int ret;
  int cnt;
  char read_filename[E_Configuration_path_size];
  char filepath[E_Configuration_path_size];

  /* CANoeのコンフィグレーションファイルのあるパスの絶対パスを取得 */
  pos = strlen(CANoe_Senario_Filepath);
  substr_cpy(filepath, CANoe_Senario_Filepath, 0, pos, elcount(filepath));

  /* 「消去・書込みルーチン」か「書換えデータ」のどちらの処理かを判定 */
  if( type == E_RoutineControl_Type_Erase )
  {
    /* ファイル読み出し(消去・書込みルーチンのファイル名) */
    ret = getProfileString( "SBL", "SBLSettingFile", "DLfile/Erase.bin", read_filename, elcount(read_filename), ext_filename );
    if( ret <= 0 || ret > E_Configuration_path_size )
    {
      /* 消去・書込みルーチンのファイル名読み出し失敗 */
      /* デフォルト値を設定しておく */
      snprintf(read_filename, elcount(read_filename), "DLfile/Erase.bin");
      Error_Log_output("TransferData_erase_init: read erase filename.");
    }
    else
    {
      /* 読み出し成功 */
      ret = E_Return_OK;
    }
  }
  else if( type == E_RoutineControl_Type_Reprog )
  {
    /* ファイル読み出し(消去・書込みルーチンのファイル名) */
    ret = getProfileString( "APL", "APLSettingFile", "DLfile/Reprog.bin", read_filename, elcount(read_filename), ext_filename );
    if( ret <= 0 || ret > E_Configuration_path_size )
    { /* 消去・書込みルーチンのファイル名読み出し失敗 */
      /* デフォルト値を設定しておく */
      snprintf(read_filename, elcount(read_filename),"DLfile/Reprog.bin");
      Error_Log_output("TransferData_reprog_init: read reprog filename.");
    }
    else
    {
      /* 読み出し成功 */
      ret = E_Return_OK;
    }
  }
  else
  {
    /* このルートは使用されない */
    Error_Log_output("RoutineControl_set_request_checkProgramming: Illiegal Type.");
  }

  /* 読み出したファイル名をIN/OUTパラメータ「filename」に設定 */
  strncat(filepath, read_filename, elcount(filepath));
  strncpy(filename, filepath, elcount(filename));

  return ret;
}

/// <General>
/* ********************************************************** */
/* Function                                                   */
/*  TransferData_Setting                                      */
/* Discription                                                */
/*  転送データに関する各種設定情報を、管理領域に設定する処理  */
/* IN :                                                       */
/*  filename : 転送データに関する設定情報を記述したファイル名 */
/*  T_Info   : 転送データに関する情報を管理する領域           */
/* OUT:                                                       */
/*  None                                                      */
/* RET:                                                       */
/*  None                                                      */
/* NOTE:                                                      */
/*  None                                                      */
/* ********************************************************** */
int TransferData_Setting( char filename[], struct S_TransferData_info T_Info[] )
{
  /* 戻り値 */
  int ret;
  int cnt;
  int elem_cnt;
  int read_cnt;
  int checkDataLength;
  long index;
  long old_offset;
  long new_offset;
  char buff[1024];
  dword fileHandle;
  dword temp_handle;
  qword temp_strtoull;
  char tempbuff[5];
  byte read_buff[E_routineControlOptionRecord_SIGNATURE];
  char result_region[5];
  char result_address[11];
  char result_size[11];
  char result_Compression[5];
  char result_Cryptogram[5];
  char result_checkTypeIdentifier[5];
  char result_checkData[258];
  char result_index[5];
  struct S_TransferData_info work_T_Info;

  /* ファイルオープン(指定モード・読み取り専用) */
  fileHandle = openFileRead(filename, E_Openfile_mode_text);
  if (fileHandle == 0)
  {
    /* ファイルオープンエラー */
    ret = E_Return_FILEOPEN_NG;

    /* デバッグ表示 */
    Error_Log_output("TransferData_Setting：openFileRead error");

    return ret;
  }

  /* RequestDownload,　TransferDataに関連する情報を管理する領域の要素数＋１回ループ */
  /* 最初の1行は見出し行の為処理スキップする */
  for(cnt = 0; cnt < (E_TransferData_info_All_Element+1); cnt++ )
  {
    /* バッファのオフセット値をクリア */
    old_offset = 0;
    new_offset = 0;

    /* 1行読み出し */
    ret = fileGetStringSZ(buff, elCount(buff), fileHandle);
    if (ret == 0)
    {
      /* EOFまで行くと0が返ってくる */
      ret = E_Return_EOF;

      /* デバッグ表示 */
      Debug_Log_output("TransferData_Setting:Read Complete!");

      /* 読むべきデータがないのでループを終了する */
      break;
    }
    else
    {
      /* 読み出し成功 */

      /* 最初の行のみ見出しなので読み捨て */
      if(cnt == 0)
      {
        continue;
      }

      /* 読み出したデータが区切り文字以外何も設定されていないかどうかを判定 */
      if( strncmp(buff, ",,,,,,,,,", elcount(buff)) == 0 )
      {
        /* 未設定のデータが見つかった時点でループを終了する */
        break;
      }

      /* ','が区切り文字なので、読み出したバッファ内で','がある位置を検索 */
      new_offset = strstr_off(buff, old_offset, ",");
      /* 「Erasefile(消去・書込みルーチンのファイル名)」を取得 */
      strncpy( work_T_Info.filename, buff, (new_offset - old_offset + 1));

      /* オフセットを更新、直前の処理でコピーしたオフセットの次の位置から再検索 */
      old_offset = new_offset + 1;

      new_offset = strstr_off(buff, old_offset, ",");
      /* 「Eraseregion（消去・書込みルーチンの仮想アドレスの一部）」を取得 */
      substr_cpy_off(result_region, 0, buff, old_offset,(new_offset - old_offset), elcount(result_region));

      /* オフセットを更新、直前の処理でコピーしたオフセットの次の位置から再検索 */
      old_offset = new_offset + 1;

      new_offset = strstr_off(buff, old_offset, ",");
      /* 「Memoryaddress（消去・書込みルーチンの仮想アドレス）」を取得 */
      substr_cpy_off(result_address, 0, buff, old_offset,(new_offset - old_offset), elcount(result_address));

      /* オフセットを更新、直前の処理でコピーしたオフセットの次の位置から再検索 */
      old_offset = new_offset + 1;

      new_offset = strstr_off(buff, old_offset, ",");
      /* 「Memorysize(消去・書込みルーチンの転送するデータサイズ)」を取得 */
      substr_cpy_off(result_size, 0, buff, old_offset,(new_offset - old_offset), elcount(result_size));

      /* オフセットを更新、直前の処理でコピーしたオフセットの次の位置から再検索 */
      old_offset = new_offset + 1;

      new_offset = strstr_off(buff, old_offset, ",");
      /* 「Compression(消去・書込みルーチンのdataFormatIdentifierの一部)」を取得 */
      substr_cpy_off(result_Compression, 0, buff, old_offset,(new_offset - old_offset), elcount(result_Compression));

      /* オフセットを更新、直前の処理でコピーしたオフセットの次の位置から再検索 */
      old_offset = new_offset + 1;

      new_offset = strstr_off(buff, old_offset, ",");
      /* 「Cryptogram(消去・書込みルーチンのdataFormatIdentifierの一部)」を取得 */
      substr_cpy_off(result_Cryptogram, 0, buff, old_offset,(new_offset - old_offset), elcount(result_Cryptogram));

      /* オフセットを更新、直前の処理でコピーしたオフセットの次の位置から再検索 */
      old_offset = new_offset + 1;

      new_offset = strstr_off(buff, old_offset, ",");
      /* 「checkTypeIdentifier（消去・書込みルーチンのcheckTypeIdentifier値）」を取得 */
      substr_cpy_off(result_checkTypeIdentifier, 0, buff, old_offset,(new_offset - old_offset), elcount(result_checkTypeIdentifier));

      /* オフセットを更新、直前の処理でコピーしたオフセットの次の位置から再検索 */
      old_offset = new_offset + 1;

      new_offset = strlen(buff);
      /* 「checkData(消去・書込みルーチンのcheckData値を記述したファイルのファイル名)」を取得 */
      substr_cpy_off(result_checkData, 0, buff, old_offset,(new_offset - old_offset), elcount(result_checkData));

      /* 処理順番(T_Infoの格納index値)」を取得する */
      /* 処理順番は上から順に設定する */
      index = cnt - 1;

      /* 消去・書込みルーチンの仮想アドレスを記述した文字列をバイト配列に変換 */
      /* 2文字=1バイトとして変換していく */
      work_T_Info.region = atol(result_region);

      /* 「転送するアドレス」を変換する */
      for( read_cnt = 0; read_cnt < (E_RequestDownload_memoryAddress_Byte-1) ; read_cnt++ )
      {
        elem_cnt = read_cnt * 2;
        tempbuff[0] = '0';
        tempbuff[1] = 'x';
        tempbuff[2] = result_address[2+elem_cnt];
        tempbuff[3] = result_address[2+elem_cnt+1];
        work_T_Info.address[(read_cnt)] = atol(tempbuff);
      }

      /* 「転送するデータサイズ」を変換する */
      for( read_cnt = 0; read_cnt < E_RequestDownload_memorySize_Byte ; read_cnt++ )
      {
        elem_cnt = read_cnt * 2;
        tempbuff[0] = '0';
        tempbuff[1] = 'x';
        tempbuff[2] = result_size[2+elem_cnt];
        tempbuff[3] = result_size[2+elem_cnt+1];
        work_T_Info.size[(read_cnt)] = atol(tempbuff);
      }

      /* データ転送時に参照するので予め整数値に変換しておく */
      snprintf(result_size, elcount(result_size), "0x%02x%02x%02x%02x",
        work_T_Info.size[0], work_T_Info.size[1],
        work_T_Info.size[2], work_T_Info.size[3]);

      ret = strtoull(result_size, temp_strtoull );
      if (ret >= 0 )
      {
        /* 読み出した消去・書込みルーチンの転送するデータのサイズ最大値を管理情報G_Reprog_General_Dataに設定 */
        work_T_Info.size_max = (temp_strtoull & 0xFFFFFFFF );
      }

      /* 「dataFormatIdentifier」を変換する */
      work_T_Info.dataFormatIdentifier[0] = atol(result_Compression) << 4;
      work_T_Info.dataFormatIdentifier[0] = work_T_Info.dataFormatIdentifier[0] | atol(result_Cryptogram);
      /* 消去・書込みルーチンのcheckTypeIdentifierを記述した文字列をバイト配列に変換 */
      /* 2文字=1バイトとして変換していく */
      work_T_Info.checkTypeIdentifier = atol(result_checkTypeIdentifier);

      /* 「checkData」を変換する */
      /* ファイル名読み出し(checkData値) */
      work_T_Info.checkDataLength[0] = 0;
      work_T_Info.checkDataLength[1] = 0;
      checkDataLength = 0;

      temp_handle = openFileRead( result_checkData, E_Openfile_mode_binary );
      if( temp_handle > 0 )
      {
        checkDataLength = fileGetBinaryBlock( work_T_Info.checkData, elcount(read_buff), temp_handle );
        if( checkDataLength == 0 )
        {
          Error_Log_output("TransferData_Setting： checkData File Read Error.");  }
        else
        {
          work_T_Info.checkDataLength[0] = (byte)((checkDataLength & 0x0000FF00) >> 8);
          work_T_Info.checkDataLength[1] = (byte)(checkDataLength & (0x000000FF));
        }
      }
      else
      {
        Error_Log_output("TransferData_Setting： checkData File Read Error.");
      }

      /* 1回の「0x36(TransferData)」で転送可能なデータサイズ */
      work_T_Info.transfer_size = 0;
      /* 消去・書込みルーチンの転送回数(blockSequenceCounterに使用するので初期値は1) */
      /* 書換えデータの転送回数(blockSequenceCounterに使用するので初期値は1) */
      work_T_Info.cnt[0] = 1;
      /* 消去・書込みルーチンの転送済みデータサイズ */
      /* 書換えデータの転送済みデータサイズ */
      work_T_Info.size_all = 0;

      /* ファイルクローズ */
      ret = fileClose(temp_handle);
      if (ret == 0)
      {
        /* デバッグ表示 */
        Error_Log_output("TransferData_Setting：fileClose error(checkData)");
      }
    }

    /* 作業用の構造体から処理順番で指定されたindexに再配置 */
    strncpy( T_Info[index].filename, work_T_Info.filename, elcount(T_Info[index].filename));
    for( read_cnt = 0; read_cnt < E_RequestDownload_memoryAddress_Byte ; read_cnt++ )
    {
      T_Info[index].address[read_cnt] = work_T_Info.address[read_cnt];
    }
    T_Info[index].region = work_T_Info.region;
    for( read_cnt = 0; read_cnt < E_RequestDownload_memorySize_Byte ; read_cnt++ )
    {
      T_Info[index].size[read_cnt] = work_T_Info.size[read_cnt];
    }
    T_Info[index].size_max = work_T_Info.size_max;
    T_Info[index].dataFormatIdentifier[0] = work_T_Info.dataFormatIdentifier[0];
    T_Info[index].checkTypeIdentifier = work_T_Info.checkTypeIdentifier;
    for( read_cnt = 0; read_cnt < E_routineControlOptionRecord_SIGNATURE  ; read_cnt++ )
    {
      T_Info[index].checkData[read_cnt] = work_T_Info.checkData[read_cnt];
    }
    T_Info[index].transfer_size = work_T_Info.transfer_size;
    T_Info[index].cnt[0] = work_T_Info.cnt[0];
    T_Info[index].size_all = work_T_Info.size_all;
    for( read_cnt = 0; read_cnt < E_routineControlOptionRecord_checkDataLength  ; read_cnt++ )
    {
        T_Info[index].checkDataLength[read_cnt] = work_T_Info.checkDataLength[read_cnt];
    }
  }

  /* 書換え対象領域の総数を設定 */
  /* 2回目の呼び出しで1回目の設定が上書きされるが、消去ルーチンの数と書き換えデータの数は一致する前提 */
  G_Reprog_General_Data.G_Info.multiple_file_num = cnt - 1;

  /* ファイルクローズ */
  ret = fileClose(fileHandle);
  if (ret == 0)
  {
    /* ファイルクローズ失敗 */
    ret = E_Return_FILECLOSE_NG;

    /* デバッグ表示 */
    Error_Log_output("TransferData_Setting：fileClose error");
  }
  else
  {
    /* ファイルクローズ成功 */
    ret = E_Return_OK;
  }

  return ret;
}


/// <General>
/* *********************************************************************** */
/* Function                                                                */
/*  Reset_Service_init                                                     */
/* Discription                                                             */
/*  外部設定情報ファイルを読み出してリセット時に使用するサービスを制御する */
/* IN :                                                                    */
/*  filename : 外部設定情報ファイル名                                      */
/* OUT:                                                                    */
/*  None                                                                   */
/* RET:                                                                    */
/*  None                                                                   */
/* NOTE:                                                                   */
/*  読み出し失敗時はSID 0x11[ECUReset(hardReset)]を使用する設定となる      */
/* *********************************************************************** */
void Reset_Service_init( char filename[] )
{
  long baudrate;

  /* ファイル読み出し(リセット時に使用するサービスの実行制御) */
  /* 読み出し失敗時はSID 0x11[ECUReset(hardReset)]を使用する設定 */
  G_Reprog_General_Data.R_Info.reset_service =
        getProfileInt("Post-Programming", "ResetService", E_Reset_Service_0x11_hs, filename);

  return;
}


/// <Reprog_Seqence>
/* *********************************************************************** */
/* Function                                                                */
/*  Reprog_Seqence_Start                                                   */
/* Discription                                                             */
/*  リプログシーケンスを実行前の初期化処理                                 */
/* IN :                                                                    */
/*  None                                                                   */
/* OUT:                                                                    */
/*  None                                                                   */
/* RET:                                                                    */
/*  canGetConfiguration()/canSetConfiguration()の処理結果 または           */
/*  E_Return_PRAMETER_NG                                                   */
/* NOTE:                                                                   */
/*  リプログのCANoeシナリオの自動実行を実施する為の初期設定を行う          */
/* *********************************************************************** */
int Reprog_Seqence_Start( void )
{
  /* 戻り値 */
  int ret;

  /* 診断記述ファイルからTP層の設定を行う */
  ret = Control_transportlayer_setup(G_Reprog_General_Data.G_Info.ecu_modifier);
  if (ret != E_Return_OK )
  {
    /* デバッグ表示 */
    Error_Log_output("Reprog_Seqence_Start:Control_transportlayer_setup error.");
  }

  /* TP層の設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    /* P2ClientとP6*Clientを設定 */
    ret = diagSetP2Timeouts(G_Reprog_General_Data.G_Info.P2Client,
                            G_Reprog_General_Data.G_Info.P6_aster_Client);
    if (ret != E_Return_OK )
    {
      /* デバッグ表示 */
      Error_Log_output("Reprog_Seqence_Start:diagSetP2Timeouts error.");
    }
  }

  /* P2ClientとP6*Clientの設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    /* デフォルトのタイムアウトハンドラ設定 */
    ret = Request_setup_timeout_handler(G_default_timeout_handler);
    if (ret != E_Return_OK )
    {
      /* デバッグ表示 */
      Error_Log_output("Reprog_Seqence_Start:Request_setup_timeout_handler error.");
    }
  }

  /* タイムアウトハンドラ設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    /* TesterPresentの周期送信を開始する */
/*    ret = diagStartTesterPresent();*/
    if (ret != E_Return_OK )
    {
      /* デバッグ表示 */
      Error_Log_output("Reprog_Seqence_Start:diagStartTesterPresent error.");
    }
  }

  return ret;
}


/// <Reprog_Seqence>
/* ****************************************************************************** */
/* Function                                                                       */
/*  Reprog_Seqence_Init                                                           */
/* Discription                                                                    */
/*  外部設定情報ファイルを読み出して ECU修飾子名と診断記述ファイル名を設定する    */
/* IN :                                                                           */
/*  filename : 外部設定情報ファイル名                                             */
/* OUT:                                                                           */
/*  None                                                                          */
/* RET:                                                                           */
/*  canGetConfiguration()/canSetConfiguration()の処理結果 または                  */
/*  E_Return_PRAMETER_NG                                                          */
/* NOTE:                                                                          */
/*  None　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　*/
/* ****************************************************************************** */
void Reprog_Seqence_Init( char filename[] )
{
   /* 戻り値 */
  int ret;
  char read_ecudef[E_External_ecudef_file_name_size];
  char read_diagdef[E_External_diagdef_file_name_size];
  int cnt;

  /* ファイル読み出し(ECU修飾子名) */
  ret = getProfileString( "General", "Ecudef", G_DIAG_DEF_CAN_NAME, read_ecudef, elcount(read_ecudef), filename );
  if( ret <= 0 || ret > E_External_ecudef_file_name_size )
  {
    /* ECU修飾子名読み出し失敗 */
    /* デフォルト値を設定しておく */
    strncpy(read_ecudef, G_DIAG_DEF_CAN_NAME, E_External_ecudef_file_name_size);
  }

  /* 読み出したECU修飾子名を管理情報G_Reprog_General_Dataに設定 */
  memcpy(G_Reprog_General_Data.G_Info.ecu_modifier, read_ecudef, elcount(read_ecudef));

  /* ファイル読み出し(診断記述ファイル名) */
  ret = getProfileString( "General", "DLL", G_DIAG_DEF_CAN_BASE_NAME, read_diagdef, elcount(read_diagdef), filename );
  if( ret <= 0 || ret > E_External_diagdef_file_name_size )
  {
    /* ECU修飾子名読み出し失敗 */
    /* デフォルト値を設定しておく */
    strncpy(read_diagdef, G_DIAG_DEF_CAN_BASE_NAME, E_External_diagdef_file_name_size);
  }

  /* 読み出した診断記述ファイル名を管理情報G_Reprog_General_Dataに設定 */
  memcpy(G_Reprog_General_Data.G_Info.diag_def_name, read_diagdef, elcount(read_diagdef));

  return;
}


/// <CAPL_Callback>
/* ****************************************************************************** */
/* Function                                                                       */
/*  _Diag_GenerateKeyResult                                                       */
/* Discription                                                                    */
/*  DLLを使用したKEY値生成の処理結果が通知されるコールバック関数                  */
/* IN :                                                                           */
/*  None                                                                          */
/* OUT:                                                                           */
/*  result      : diagGenerateKeyFromSeed()の処理結果                             */
/*  computedKey : 生成されたキー値                                                */
/* RET:                                                                           */
/*  None                                                                          */
/* NOTE:                                                                          */
/*  シードキーの生成に1ms以上かかるときはdiagGenerateKeyFromSeed()の結果ではなく  */
/*  こちらのハンドラが呼ばれるらしいが、diagGenerateKeyFromSeed()の               */
/*  OUTパラメータにキー値を格納する領域を設定しておくと、                         */
/*  そちらにキー値が設定されてこちらのハンドラは実行されない模様                  */
/* ****************************************************************************** */
_Diag_GenerateKeyResult(long result, BYTE computedKey[])
{
    /* デバッグ表示 */
    Debug_Log_output("_Diag_GenerateKeyResult CALLBACK");
}


/// <CAPL_Callback>
/* ****************************************************************************** */
/* Function                                                                       */
/*  default_timeout_handler                                                       */
/* Discription                                                                    */
/*  デフォルトのタイムアウト検出時のハンドラ関数                                  */
/* IN :                                                                           */
/*  None                                                                          */
/* OUT:                                                                           */
/*  None                                                                          */
/* RET:                                                                           */
/*  None                                                                          */
/* NOTE:                                                                          */
/*  None                                                                          */
/* ****************************************************************************** */
void default_timeout_handler(void)
{
  Debug_Log_output("default_timeout_handler: timeout detected.");

  return;
}

