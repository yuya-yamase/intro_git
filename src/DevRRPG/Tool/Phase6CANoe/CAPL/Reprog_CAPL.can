/*                           system                               */
/* ************************************************************** */

/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 'o'                                                 */
/* Discription                                                 */
/*  指定のキー('o')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  トランスポート層の初期設定のみを実行する                   */
/*  シナリオとは別にキー押下で直接リクエストを                 */
/*  送信する処理の為の対応                                     */
/* *********************************************************** */
on key 'o'
{
  int ret;

  /* デバッグ表示 */
  Debug_Log_output("Debug Transport Setting");

  /* 初期設定を実行 */
  ret = Reprog_Seqence_Start();
  /* 初期設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    write("Setup Done.");
  }

  return;
}

/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key '1'                                                 */
/* Discription                                                 */
/*  指定のキー('1')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  SID 0x22のFingerpirnt領域(#0～#2)の読み出しサービスを起動  */
/*  シナリオとは別にキー押下で直接リクエストを送信する処理     */
/* *********************************************************** */
on key '1'
{
  int ret;
  /* dataIdentifierの値を設定しておく領域 */
  byte dataIdentifier_buff[7];

  /* デバッグ表示 */
  Debug_Log_output("Debug Send to ReadDataByIdentifier(Finger Print)");

  diagResize( G_ReadDataByIdentifier_req_02, 7 );
  /* Fingerprint #0～#2 */
  dataIdentifier_buff[0] = 0x22;
  dataIdentifier_buff[1] = 0xF1;
  dataIdentifier_buff[2] = 0x20;
  dataIdentifier_buff[3] = 0xF1;
  dataIdentifier_buff[4] = 0x21;
  dataIdentifier_buff[5] = 0xF1;
  dataIdentifier_buff[6] = 0x22;
  diagSetPrimitiveData ( G_ReadDataByIdentifier_req_02, dataIdentifier_buff, 7 );
  ret = diagSendRequest( G_ReadDataByIdentifier_req_02 );

  return;
}


