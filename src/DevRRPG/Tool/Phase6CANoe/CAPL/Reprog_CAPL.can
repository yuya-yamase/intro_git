/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  SID 0x22のFingerpirnt領域(#1～#6)の読み出しサービスを起動  */
/*  シナリオとは別にキー押下で直接リクエストを送信する処理     */
/* *********************************************************** */
on key '2'
{
  /* デバッグ表示 */
  Debug_Log_output("Debug Send to ReadDataByIdentifier(Finger Print)");

  /* SID 0x22 リクエスト送信 */
  ReadDataByIdentifier_req_distribution(E_dataIdentifier_asfp_01 ,E_Flag_OFF);

  return;
}


