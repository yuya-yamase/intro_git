/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 'a'                                                 */
/* Discription                                                 */
/*  指定のキー('a')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  CANoeシナリオのAPL起動要求待ち状態となる                   */
/*  SID 0x10 (ProgrammingSession)のポジティブレスポンスを      */
/*  受信後にCANoeシナリオの自動実行を開始する                  */
/* *********************************************************** */
on key 'a'
{
  int ret;

  /* デバッグ表示 */
  Debug_Log_output("CANoe Senario APL Start Waiting");

  /* 初期設定を実行 */
  ret = Reprog_Seqence_Start();
  /* 初期設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    /* デバッグ表示 */
    Debug_Log_output("APL_Start:Waiting APL Start Request");

    /* CANoeシナリオのAPL起動要求有効フラグをONにする */
    G_Reprog_General_Data.G_Info.enable_aplstart = E_Flag_ON;
  }

  return;
}


/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 'b'                                                 */
/* Discription                                                 */
/*  指定のキー('b')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  TesterPresentの周期実行を開始                              */
/* *********************************************************** */
on key 'b'
{
  long ret;

  ret = diagStartTesterPresent();
  if (ret != E_Return_OK )
  {
    /* デバッグ表示 */
    Error_Log_output("diagStartTesterPresent error.");
  }
  else
  {
    /* ユーザが視認できるよう出力windowに表示 */
    write("SID 0x3E send start.");
  }

  return;
}

/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 'v'                                                 */
/* Discription                                                 */
/*  指定のキー('v')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  TesterPresentの周期実行を停止                              */
/* *********************************************************** */
on key 'v'
{
  long ret;

  ret = diagStopTesterPresent();
  if (ret != E_Return_OK )
  {
    /* デバッグ表示 */
    Error_Log_output("diagStopTesterPresent error.");
  }
  else
  {
    /* ユーザが視認できるよう出力windowに表示 */
    write("SID 0x3E send stop.");
  }

  return;
}


/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 's'                                                 */
/* Discription                                                 */
/*  指定のキー('s')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  CANoeシナリオの自動実行を開始する                          */
/* *********************************************************** */
on key 's'
{
  int ret;

  /* デバッグ表示 */
  Debug_Log_output("CANoe Senario Start");

  /* 初期設定を実行 */
  ret = Reprog_Seqence_Start();

  /* 初期設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    /* デバッグ表示 */
    Debug_Log_output("Reprog_Seqence_Start:Reprogramming Seqence Start");

    /* 自動実行を有効化する */
    G_Reprog_General_Data.G_Info.enable_autorun = E_Flag_ON;

    CANoe_Seqence_Direct_Update(E_PP1_SID_0x22_swi_req);

    /* CANoeシナリオの開始直前の時間測定 */
    G_Timespec_Array[E_Timespec_Seqence_Start] = timeNowInt64();

    /* CANoeシナリオの起点となるリクエストの送信を実施 */
    /* 以後はレスポンス受信/タイムアウトのイベント毎に次の処理を行う */
    Request_sender();
  }

  return;
}


/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 'z'                                                 */
/* Discription                                                 */
/*  指定のキー('z')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  CANoeシナリオの自動実行を開始する                          */
/* *********************************************************** */
on key 'z'
{
  int ret;

  /* デバッグ表示 */
  Debug_Log_output("CANoe Senario Start");

  /* 初期設定を実行 */
  ret = Reprog_Seqence_Start();

  /* 初期設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    /* デバッグ表示 */
    Debug_Log_output("Reprog_Seqence_Start:Reprogramming Seqence Start");

    /* 自動実行を有効化する */
    G_Reprog_General_Data.G_Info.enable_autorun = E_Flag_ON;

    //Reprog_Ext.ini の[TesterPresent] addrtypeを0x1とする。
    TesterPresent_request_02_send(); //機能アドレスかつSPRMIB=Trueで3Eを送信
    setTimer(TwaitTimer, 1 * 1000); // 機能アドレスの応答が破棄されるまで1 秒待ち
    CANoe_Seqence_Direct_Update(E_PP1_SID_0x27_seed_req);

    /* CANoeシナリオの開始直前の時間測定 */
    G_Timespec_Array[E_Timespec_Seqence_Start] = timeNowInt64();

    /* CANoeシナリオの起点となるリクエストの送信を実施 */
    /* 以後はレスポンス受信/タイムアウトのイベント毎に次の処理を行う */
    Request_sender();
  }

  return;
}

/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key ','                                                 */
/* Discription                                                 */
/*  指定のキー(',')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  CANoeシナリオの自動実行を開始する                          */
/* *********************************************************** */
on key ','
{
  int ret;

  /* デバッグ表示 */
  Debug_Log_output("CANoe Senario Start");

  /* 初期設定を実行 */
  ret = Reprog_Seqence_Start();

  /* 初期設定が成功している場合のみ次の処理を行う */
  if (ret == E_Return_OK )
  {
    /* デバッグ表示 */
    Debug_Log_output("Reprog_Seqence_Start:StayInBoot Seqence Start");

    /* 自動実行を有効化する */
    G_Reprog_General_Data.G_Info.enable_autorun = E_Flag_ON;

    /* SID 0x10 DiagnosticSessionControl(ProgrammingSession) 送信から */
    CANoe_Seqence_Direct_Update(E_PP1_SID_0x10_prog_req);

    /* CANoeシナリオの開始直前の時間測定 */
    G_Timespec_Array[E_Timespec_Seqence_Start] = timeNowInt64();

    /* CANoeシナリオの起点となるリクエストの送信を実施 */
    /* 以後はレスポンス受信/タイムアウトのイベント毎に次の処理を行う */
    Request_sender();
  }

  return;
}

/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 'q'                                                 */
/* Discription                                                 */
/*  指定のキー('q')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  CANoeでの測定を停止する(CANoeは終了しない)                 */
/* *********************************************************** */
on key 'q'
{
  /* 特に後処理は不要なのでそのまま終了する */

    /* デバッグ表示 */
  Debug_Log_output("CANoe Senario Stop");

  /* 測定を停止(CANoeは起動したまま) */
  stop();

  return;
}


/// <on_key_Event>
/* *********************************************************************** */
/* Function                                                                */
/*  on key 'c'                                                             */
/* Discription                                                             */
/*  指定のキー('c')が押下された際に起動するイベントハンドラ                */
/* IN :                                                                    */
/*  None                                                                   */
/* OUT:                                                                    */
/*  None                                                                   */
/* RET:                                                                    */
/*  None                                                                   */
/* NOTE:                                                                   */
/*  CANoeシーケンス停止機能でシナリオ停止後、再度CANoeシーケンスを再開する */
/* *********************************************************************** */
on key 'c'
{
    /* デバッグ表示 */
  Debug_Log_output("CANoe Senario ReStart");

  /* 自動実行を有効化する */
  G_Reprog_General_Data.G_Info.enable_autorun = E_Flag_ON;

  /* CANoeシーケンスの停止時点からの起点となるリクエストの送信を実施 */
  /* 以後はレスポンス受信/タイムアウトのイベント毎に次の処理を行う */
  Request_sender();

  return;
}


/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key '@'                                                 */
/* Discription                                                 */
/*  指定のキー('@')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  SID 0x22のアクティブセッションの読み出しサービスを起動     */
/*  シナリオとは別にキー押下で直接リクエストを送信する処理     */
/* *********************************************************** */
on key '@'
{
  /* デバッグ表示 */
  Debug_Log_output("Debug Send to ReadDataByIdentifier(Active Session)");

  /* SID 0x22 リクエスト送信 */
  ReadDataByIdentifier_req_distribution(E_dataIdentifier_ActiveDiagnosticSession ,E_Flag_OFF);

  return;
}


/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 't'                                                 */
/* Discription                                                 */
/*  指定のキー('t')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  SID 0x10のdefault sessionへの遷移を行うサービスを起動      */
/*  シナリオとは別にキー押下で直接リクエストを送信する処理     */
/* *********************************************************** */
on key 't'
{
  int ret;

  /* デバッグ表示 */
  Debug_Log_output("Debug Send to ReadDataByIdentifier(Default Session)");

  /* リクエスト送信(DiagnosticSessionControl(defaultSession)) */
  ret = DiagnosticSessionControl_req_distribution( E_Send_Address_Func, E_diagnosticSessionType_defaultSession, E_Flag_OFF );
  if ( ret != E_Return_OK )
  {
    /* リクエスト送信エラー */
    Error_Log_output("Request_sender: Request Send Error. E_PP1_SID_0x10_def_req.");
  }

  return;
}


/// <on_key_Event>
/* *********************************************************** */
/* Function                                                    */
/*  on key 'p'                                                 */
/* Discription                                                 */
/*  指定のキー('p')が押下された際に起動するイベントハンドラ    */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  SID 0x3Eをシナリオとは別にキー押下で直接送信する処理       */
/* *********************************************************** */
on key 'p'
{
  int ret;

  /* デバッグ表示 */
  Debug_Log_output("Debug Send to TesterPresent");

  if( G_Reprog_General_Data.TP_Info.testerPresentSprmib == 0x0 )
  {
    /* リクエスト送信(TesterPresent(SPRMIB=0x0)) */
    ret = TesterPresent_request_01_send();
  }
  else
  {
    /* リクエスト送信(TesterPresent(SPRMIB=0x1)) */
    ret = TesterPresent_request_02_send();
  }

  if ( ret != E_Return_OK )
  {
    /* リクエスト送信エラー */
    Error_Log_output("Request_sender: Request Send Error. SID_0x3E.");
  }

  return;
}


/// <on_system_evnet>
/* *********************************************************** */
/* Function                                                    */
/*  on preStart                                                */
/* Discription                                                 */
/*  CANoeのStart(開始)押下時に起動するイベントハンドラ         */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* *********************************************************** */
on preStart
{
  /* CanoeをStart押下時に起動するイベントハンドラ */

  /* 動作中のCANoeシナリオのコンフィグレーションファイルが格納されているディレクトリのフルパスを取得 */
  getAbsFilePath("", CANoe_Senario_Filepath, elcount(CANoe_Senario_Filepath));

  /* グローバル変数の一括初期化 */
  variable_initialize();

  /* デバッグ表示 */
  write("Reprog_CAPL Initialize Complete");

  return;
}


/// <on_system_evnet>
/* *********************************************************** */
/* Function                                                    */
/*  on start                                                   */
/* Discription                                                 */
/*  PreStartイベントの後に起動するイベントハンドラ             */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  トレースウィンドウ上に実装済みのKeyEventの説明を出力する   */
/* *********************************************************** */
on start
{
  /* PreStartイベントの後に起動するイベントハンドラ */

  long pos;
  char debug_filepath[E_Configuration_path_size];
  char msg_buff[128]="********************** Start CANoe **********************\n";

  /* デバッグログファイルの出力パスを指定 */
  /* CANoeのコンフィグレーションファイルのあるパスの絶対パスを取得 */
  pos = strlen(CANoe_Senario_Filepath);
  substr_cpy(debug_filepath, CANoe_Senario_Filepath, 0, pos, elcount(debug_filepath));
  /* CANoeのコンフィグレーションファイルのあるパスからの相対パス指定を追加する */
  strncat(debug_filepath, "Log", elcount(debug_filepath));
  /* デバッグログの書込み先のファイルパスを設定 */
  setWritePath(debug_filepath);

  /* 書込みモード(追記モード)でデバッグログファイルをオープンする */
  G_debug_log_file_handle = OpenFileWrite("CANoe_debug.log", 2);
  if ( G_debug_log_file_handle != 0 )
  {
    /* 仕切り用のメッセージを出力しておく */
    filePutString (msg_buff, elcount(msg_buff), G_debug_log_file_handle);
  }
  else
  {
    /* オープン失敗時は出力windowへエラー通知 */
    write ("CANoe_debug.log Open Error, OpenFileWrite.");
  }

  /* CAPL Key Event Guide */
  write("************************************************");
  write(" Press 's' to Start Reprog CANoe Senario");
  write(" Press 'z' to APL Start Request");
  write(" Press ',' to Stay In Boot Request");
  write("************************************************");

  return;
}


/// <on_system_evnet>
/* *********************************************************** */
/* Function                                                    */
/*  on stopMeasurement                                         */
/* Discription                                                 */
/*  CANoeの測定停止時に呼び出されるイベントハンドラ            */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  終了処理を行う                                             */
/* *********************************************************** */
on stopMeasurement
{
  /* 終了時に時間測定結果をデバッグログファイルに出力する */
  Timespec_Log_output();

  /* デバッグログファイルをクローズする */
  fileClose(G_debug_log_file_handle);

  /* ハンドラには無効値を設定しておく */
  G_debug_log_file_handle = 0;

  return;
}



/* *********************************************************** */
/* Function                                                    */
/*  on timer APL_Start_Request_Timer                           */
/* Discription                                                 */
/*  APL要求起動の実処理                                        */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  APL要求起動の判定の為にのみ使用する。                      */
/*  CANの受信ハンドラ内で本関数内の処理を実行すると、          */
/*  diagResponseのハンドラ受信前にdiagRequestを行うので、      */
/*  APL要求起動で使用したSID 0x10のポジティブレスポンスが      */
/*  diagResponseの受信ハンドラで起動してしまう為、遅延実行している */
/* *********************************************************** */
on timer APL_Start_Request_Timer
{
  /* APL起動要求によりCANoeシーケンスの実行開始 */
  Debug_Log_output("APL Start:Reprogramming Seqence Start");

  /* 自動実行を有効化する */
  G_Reprog_General_Data.G_Info.enable_autorun = E_Flag_ON;

  /* APL要求起動の有効フラグはもう不要なのでフラグを落とす */
  G_Reprog_General_Data.G_Info.enable_aplstart = E_Flag_OFF;

  /* CANoeシナリオの開始直前の時間測定 */
  G_Timespec_Array[E_Timespec_Seqence_Start] = timeNowInt64();

  /* APL要求起動時はSID 0x10[DiagnosticSessionControl]のProgrammingSessionのポジティブレスポンス受信以降から再開となる */
  CANoe_Seqence_Direct_Update(E_PP1_SID_0x27_seed_req);

  /* SID 0x27 SecurityAccess(requestSeed)がCANoeシナリオ停止機能の対象となっている可能性があるのでここでも判定 */
  CANoe_Seqence_Stop_Check();

  /* APL起動要求待ち中にSID 0x10 [DiagnosticSessionControl]のProgrammingSessionのポジティブレスポンスを受信したので、 */
  /* CANoeシナリオの起点となるリクエストの送信を実施 */
  Request_sender();

  return;
}



/* *********************************************************** */
/* Function                                                    */
/*  on timer TwaitTimer                                        */
/* Discription                                                 */
/*  SID0x10(PrgSession) 応答受けてから、SID 0x27(Seed) 出す    */
/*  までの Wait タイマ                                         */
/* IN :                                                        */
/*  None                                                       */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  None                                                       */
/* *********************************************************** */
on timer TwaitTimer
{
  /* 次のリクエストの送信を実施 */
  Request_sender();

  return;
}

/* ************************************************************** */
/*                            CAN                                 */
/* ************************************************************** */

/* *********************************************************** */
/* Function                                                    */
/*  on message 0x18daf140                                      */
/* Discription                                                 */
/*  CAN ID：0x18daf140の受信ハンドラ関数                       */
/* IN :                                                        */
/*  message型のオブジェクト                                    */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  APL要求起動の判定の為にのみ使用する                        */
/*  デバッグしやすくする為variable_initialize()による初期化後  */
/*   かつ　APL要求起動待ち中のみ処理が有効になる               */
/* *********************************************************** */
on message 0x18dae017x  /* ^^^ */
{
  long first_byte;
  long second_byte;

  /* 「初期化済み」かどうかを判定 */
  /* 「初期化済み」でない場合は特に何もせず受信データを読み捨て */
  if (G_Reprog_General_Data.G_Info.initialze == E_Flag_ON )
  {
    /* 初期化済み かつ 自動実行の有効フラグがOFF かつ APL起動要求の有効フラグがONの場合のみAPL起動要求判定を行う */
    if( G_Reprog_General_Data.G_Info.enable_autorun == E_Flag_OFF &&
         G_Reprog_General_Data.G_Info.enable_aplstart == E_Flag_ON )
    {

      /* 受信データがSID 0x10 (ProgrammingSession)のポジティブレスポンスであるか判定 */
      /* APL起動要求待ち中ではSID 0x10 (ProgrammingSession)のポジティブレスポンス以外は無視する */
      /* SID 0x10 (ProgrammingSession)のポジティブレスポンスは、1バイト目が'0x50'で2バイト目が'0x02' */
      /* 1バイト目を読み出し(エラーチェックはこの後の読み出し値のチェックで代用するので不要)*/
      first_byte = this.BYTE(1);
      /* 2バイト目を読み出し(エラーチェックはこの後の読み出し値のチェックで代用するので不要)*/
      /* TBD:SID 0x37のレスポンス受信時にWarningが出るが処理に影響はないので低優先対応する */
      second_byte = this.BYTE(2);

      /* SID 0x10 (ProgrammingSession)のポジティブレスポンスであるか判定 */
      if( first_byte == 0x50 && second_byte == 0x02 )
      {
        /* APL要求起動受信時の遅延起動用タイマを設定 */
        /* 現在の動作しているCANの受信ハンドラは一度終了させる必要がある */
        setTimer(APL_Start_Request_Timer , G_Reprog_General_Data.G_Info.aplstart_wait);
      }
    }
    else
    {
      /* 「初期化済み かつ 自動実行の有効フラグがON」でない */
      /* このような場合は特に何もせず受信データを読み捨て */

      /* デバッグ表示(性能に影響するのでデバッグ時のみ有効にすること) */
      /* Debug_Log_output("Not Initialize. Discard Receive CAN Message"); */
    }
  }

  return;
}


/* ************************************************************** */
/*                        Diagnostics                             */
/* ************************************************************** */

/* *********************************************************** */
/* Function                                                    */
/*  on diagResponse *                                          */
/* Discription                                                 */
/*  レスポンス受信時に起動する受信ハンドラ関数                 */
/* IN :                                                        */
/*  diagResponse型のオブジェクト                               */
/* OUT:                                                        */
/*  None                                                       */
/* RET:                                                        */
/*  None                                                       */
/* NOTE:                                                       */
/*  ポジティブ/ネガティブ問わずレスポンス受信時に実行する      */
/*  デバッグしやすくする為variable_initialize()による初期化後  */
/*   かつ　CANoeシナリオ自動実行中のみ処理が有効になる         */
/* *********************************************************** */
on diagResponse *
{
  Diag_Response_handler(this);

  return;
}

on diagResponse TesterPresent_zeroSubFunction_SPRMIB
{
  write("TP Received");
}

on diagRequest TesterPresent_zeroSubFunction_SPRMIB
{
  write("TP Send");
}

/* ************************************************************** */
/*                        Functions                               */
/* ************************************************************** */

/// <General>
/* **************************************************** */
/* Function                                             */
/*  variable_initialize                                 */
/* Discription                                          */
/*  グローバル変数の初期化                              */
/* IN :                                                 */
/*  filename : 外部設定情報ファイル名                   */
/* OUT:                                                 */
/*  None                                                */
/* RET:                                                 */
/*  None                                                */
/* NOTE:                                                */
/*  None                                                */
/* **************************************************** */
void variable_initialize(void)
{
  long pos;
  int cnt;
  char extend_filepath[E_Configuration_path_size];
  char filename[E_Configuration_path_size];

  /* デバッグログファイルの出力パスを指定 */
  /* CANoeのコンフィグレーションファイルのあるパスの絶対パスを取得 */
  pos = strlen(CANoe_Senario_Filepath);
  substr_cpy(extend_filepath, CANoe_Senario_Filepath, 0, pos, elcount(extend_filepath));

  /* CANoeのコンフィグレーションファイルのあるパスからの相対パス指定を追加する */
  strncat(extend_filepath, G_EXTEND_FILE_NAME, elcount(extend_filepath));

  /* ReprogのCANoeシーケンスを制御する為の管理情報の初期設定 */
  G_Reprog_General_Data.G_Info.pp1_process = E_PP1_Seqence_Start;
  G_Reprog_General_Data.G_Info.pp2_process = E_PP2_Seqence_Num_Start;
  G_Reprog_General_Data.G_Info.multiple_file_count = 0;
  G_Reprog_General_Data.G_Info.check_count = 0;
  G_Reprog_General_Data.S_Info.nonce_cnt = 0;
  G_Reprog_General_Data.S_Info.asfp_cnt = 0;

  /* 自動実行用に初期値を設定 */
  G_Reprog_General_Data.G_Info.enable_autorun = E_Flag_OFF;
  G_Reprog_General_Data.G_Info.enable_aplstart = E_Flag_OFF;
  G_Reprog_General_Data.G_Info.initialze = E_Flag_ON;
  G_Reprog_General_Data.G_Info.stop_process = 0xFF;
  G_Reprog_General_Data.G_Info.stop_lb = 0x00;
  G_Reprog_General_Data.G_Info.stop_bsc = 0x01;

  /* P2Clientの設定(ここではデフォルト値設定) */
  G_Reprog_General_Data.G_Info.P2Client = (G_timer_p2_max + G_timer_p2_server_max);
  /* P6*Clientの設定(ここではデフォルト値設定) */
  G_Reprog_General_Data.G_Info.P6_aster_Client = (G_timer_p6_max + G_timer_p2_aster_server_max);

  /* デフォルトのタイムアウト値を設定 */
  diagSetTimeout(G_Request_timeout_default);

  /* シード値とキー値を初期化 */
  SecurityAccess_Clear_SeedKey(E_SecuritySeed_Byte, E_SecurityKey_Byte);

  /* ツール認証キーを設定 */
  SecurityAccess_init(extend_filepath);

  /* 暗号化ツール側で使用したNonce値と、テスターシリアル番号を外部設定情報から読み出して設定する */
  WriteDataByIdentifier_init(extend_filepath);

  /* 転送データ読み出しに使用するバッファの最大値 */
  /* 動的なメモリ取得が出来なそうなので仮決めの値で制限する */
  G_Reprog_General_Data.transferdata_readsize_max = E_readbuff_maxsize;

  /* 消去・書込みルーチンの管理情報を設定 */
  TransferData_Setting_Filename(E_RequestDownload_Type_Erase, filename, extend_filepath);

  TransferData_Setting(filename, G_TransferData_Info_Erase);
  /* 書換えデータの管理情報を設定 */
  TransferData_Setting_Filename(E_RequestDownload_Type_Reprog, filename, extend_filepath);
  TransferData_Setting(filename, G_TransferData_Info_Reprog);

  /* APL要求起動時、初回のリクエスト送信のみの遅延タイマ値読み出し */
  CANoe_APLStart_Waittime(extend_filepath);

  /* CANoeシナリオの停止機能の対象となっているSIDを設定 */
  CANoe_Seqence_Stop_Setting(extend_filepath);

  /* SID 0x10 DiagnosticSessionControl(extendedDiagnosticSession)送信時のSPRMIB設定を取得 */
  DiagnosticSessionControl_init(extend_filepath);

  /* Sid 0x22 [ReadDataByIdentifier]の実行可否を取得 */
  ReadDataByIdentifier_init(extend_filepath);

  /* Sid0x3E [TesterPresent]のパラメータ設定を取得 */
  TesterPresent_init(extend_filepath);

  /* Sid0x31 [RoutineControl(ValidateApplication_init)]のパラメータ設定を取得 */
  ValidateApplication_init(extend_filepath);

  /* リセット時に使用するサービスの制御の情報を取得 */
  Reset_Service_init(extend_filepath);

  /* 初期設定情報を読み出し */
  Reprog_Seqence_Init(extend_filepath);

  /* 時間測定の全測定箇所の初期値設定を行うまでループ */
  for( cnt = 0; cnt < E_Timespec_Seqence_MAX; cnt++ )
  {
    /* 初期値設定 */
    G_Timespec_Array[cnt] = 0;
  }

  return;
}


/// <General>
/* ********************************************************** */
/* Function                                                   */
/*  CANoe_Seqence_Request_Update                              */
/* Discription                                                */
/*  リクエスト送信後にシーケンス位置を次の位置に更新          */
/* IN :                                                       */
/*  None                                                      */
/* OUT:                                                       */
/*  None                                                      */
/* RET:                                                       */
/*  None                                                      */
/* NOTE:                                                      */
/*  正常系でのリクエスト送信成功時にシーケンス位置更新に使用  */
/* ********************************************************** */
void CANoe_Seqence_Request_Update( void )
{
  /* 現在のシーケンス位置を判定し、その次のシーケンス位置に更新する */

  if( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x22_hwi_req )
  {
    /* SID 0x22 vehicleManufacturerECUHardwareNumberDataIdentifier 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x22_hwi_posres;
  }
  else if( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x22_swi_req )
  {
    /* SID 0x22 vehicleManufacturerECUSoftwareNumberDataIdentifier 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x22_swi_posres;
  }
  else if( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_ext_req )
  {
    /* SID 0x10 DiagnosticSessionControl(extendedDiagnosticSession) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x10_ext_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x28_rxtx_req )
  {
    /* SID 0x28 CommunicationControl(disableRxAndTx) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x28_rxtx_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_prog_req )
  {
    /* SID 0x10 DiagnosticSessionControl(ProgrammingSession) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x10_prog_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x27_seed_req )
  {
    /* SID 0x27 SecurityAccess(requestSeed) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x27_seed_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x27_key_req )
  {
    /* SID 0x27 SecurityAccess(sendKey) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x27_key_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x2E_asfp_req )
  {
    /* SID 0x2E WriteDataByIdentifier(applicationSoftwareFingerprint) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x2E_asfp_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x2E_nonce_req )
  {
    /* SID 0x2E WriteDataByIdentifier(Nonce) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x2E_nonce_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x34_SBL_req )
  {
    /* SID 0x34 RequestDownload(消去・書込みルーチン) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x34_SBL_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x36_dl_SBL_req )
  {
    /* SID 0x36 TransferData(ダウンロード) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x36_dl_SBL_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x37_SBL_req )
  {
    /* SID 0x37 RequestTransferExit(消去・書込みルーチン) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x37_SBL_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_signature_req )
  {
    /* SID 0x31 RoutineControl(checkMemoryFlashdriver) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_mfd_signature_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_cmac_req )
  {
    /* SID 0x31 RoutineControl(checkMemoryFlashdriver) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_mfd_cmac_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_crc_req )
  {
    /* SID 0x31 RoutineControl(checkMemoryFlashdriver) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_mfd_crc_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_erase_req )
  {
    /* SID 0x31 RoutineControl(eraseMemory) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_erase_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x34_APL_req )
  {
    /* SID 0x34 RequestDownload(書換えデータ) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x34_APL_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x36_dl_APL_req )
  {
    /* SID 0x36 TransferData(ダウンロード) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x36_dl_APL_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x37_APL_req )
  {
    /* SID 0x37 RequestTransferExit(書換えデータ) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x37_APL_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_signature_req )
  {
    /* SID 0x31 RoutineControl(checkMemorySoftwareData) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_msd_signature_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_cmac_req )
  {
    /* SID 0x31 RoutineControl(checkMemorySoftwareData) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_msd_cmac_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_crc_req )
  {
    /* SID 0x31 RoutineControl(checkMemorySoftwareData) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_msd_crc_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_valid_req )
  {
    /* SID 0x31 RoutineControl(validApplication) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_valid_sig_req )
  {
    /* SID 0x31 RoutineControl(validApplication) 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_sig_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x11_ECUReset_req )
  {
    /* SID 0x11 ECUReset 送信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x11_ECUReset_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_def_req )
  {
    /* SID 0x10 DiagnosticSessionControl(defaultSession) 送信 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x10_def_posres;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_Seqence_Normal_End )
  {
    /* 正常終了状態 */
    /* 処理無し */
  }
  else
  {
    /* CANoe_Seqence_Direct_Updateで変な値にしていない限りエラーは発生しない */
    Error_Log_output("CANoe_Seqence_Request_Update: Illigal Seqence.");
  }

  return;
}


/// <General>
/* ******************************************************************  */
/* Function                                                            */
/*  CANoe_Seqence_Response_Update                                      */
/* Discription                                                         */
/*  レスポンス受信後にシーケンス位置を次の位置に更新                   */
/* IN :                                                                */
/*  None                                                               */
/* OUT:                                                                */
/*  None                                                               */
/* RET:                                                                */
/*  None                                                               */
/* NOTE:                                                               */
/*  正常系でのポジティブレスポンス受信成功時にシーケンス位置更新に使用 */
/*  SPRMIBをONにして送信したリクエストのタイムアウト時にもこちらを使用 */
/* ******************************************************************* */
void CANoe_Seqence_Response_Update( void )
{
  /* 現在のシーケンス位置を判定し、その次のシーケンス位置に更新する */

  if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x22_hwi_posres )
  {
    /* SID 0x22 vehicleManufacturerECUHardwareNumberDataIdentifier ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x10_ext_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x22_swi_posres )
  {
    /* SID 0x22 vehicleManufacturerECUSoftwareNumberDataIdentifier ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x22_hwi_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_ext_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(extendedDiagnosticSession) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x28_rxtx_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x28_rxtx_posres )
  {
    /* SID 0x28 CommunicationControl(disableRxAndTx) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x10_prog_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_prog_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(ProgrammingSession) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x27_seed_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x27_seed_posres )
  {
    /* SID 0x27 SecurityAccess(requestSeed) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x27_key_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x27_key_posres )
  {
    /* SID 0x27 SecurityAccess(sendKey) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x2E_asfp_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x2E_asfp_posres )
  {
    /* SID 0x2E WriteDataByIdentifier(applicationSoftwareFingerprint) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x2E_nonce_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x2E_nonce_posres )
  {
    /* SID 0x2E WriteDataByIdentifier(Nonce) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x34_SBL_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x34_SBL_posres )
  {
    /* SID 0x34 RequestDownload(消去・書込みルーチン) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x36_dl_SBL_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x36_dl_SBL_posres )
  {
    /* SID 0x36 TransferData(ダウンロード) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x37_SBL_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x37_SBL_posres )
  {
    if ( G_TransferData_Info_Erase[G_Reprog_General_Data.G_Info.multiple_file_count].checkTypeIdentifier == 1 )
    {
      /* SID 0x37 RequestTransferExit(消去・書込みルーチン) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_mfd_signature_req;
    }
    else if ( G_TransferData_Info_Erase[G_Reprog_General_Data.G_Info.multiple_file_count].checkTypeIdentifier == 3 )
    {
      /* SID 0x37 RequestTransferExit(消去・書込みルーチン) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_mfd_cmac_req;
    }
    else if ( G_TransferData_Info_Erase[G_Reprog_General_Data.G_Info.multiple_file_count].checkTypeIdentifier == 2 )
    {
      /* SID 0x37 RequestTransferExit(消去・書込みルーチン) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_mfd_crc_req;
    }
    else
    {
      /* SID 0x37 RequestTransferExit(消去・書込みルーチン) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_erase_req;
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_signature_posres )
  {
    /* SID 0x37 RequestTransferExit(消去・書込みルーチン) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_erase_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_cmac_posres )
  {
    /* SID 0x37 RequestTransferExit(消去・書込みルーチン) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_erase_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_mfd_crc_posres )
  {
    /* SID 0x31 RoutineControl(checkMemoryFlashdriver) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_erase_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_erase_posres )
  {
    /* SID 0x31 RoutineControl(eraseMemory) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x34_APL_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x34_APL_posres )
  {
    /* SID 0x34 RequestDownload(書換えデータ) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x36_dl_APL_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x36_dl_APL_posres )
  {
    /* SID 0x36 TransferData(ダウンロード) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x37_APL_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x37_APL_posres )
  {
    if ( G_TransferData_Info_Reprog[G_Reprog_General_Data.G_Info.multiple_file_count].checkTypeIdentifier == 1 )
    {
      /* SID 0x37 RequestTransferExit(書換えデータ) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_msd_signature_req;
    }
    else if ( G_TransferData_Info_Reprog[G_Reprog_General_Data.G_Info.multiple_file_count].checkTypeIdentifier == 3 )
    {
      /* SID 0x37 RequestTransferExit(書換えデータ) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_msd_cmac_req;
    }
    else if ( G_TransferData_Info_Reprog[G_Reprog_General_Data.G_Info.multiple_file_count].checkTypeIdentifier == 2 )
    {
      /* SID 0x37 RequestTransferExit(書換えデータ) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_check_msd_crc_req;
    }
    else
    {
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_req;
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_signature_posres )
  {
    if ( G_Reprog_General_Data.VLD_Info.sendOptionRecord == 0x1 )
    {
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_sig_req;
    }
    else if ( G_Reprog_General_Data.VLD_Info.sendOptionRecord == 0x0 )
    {
     /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
     G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_req;
    }
    else
    {
      /* 異常系確認ルート */
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_req;
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_cmac_posres )
  {
    if ( G_Reprog_General_Data.VLD_Info.sendOptionRecord == 0x1 )
    {
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_sig_req;
    }
    else if ( G_Reprog_General_Data.VLD_Info.sendOptionRecord == 0x0 )
    {
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_req;
    }
    else
    {
      /* 異常系確認ルート */
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_req;
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_check_msd_crc_posres )
  {
    if ( G_Reprog_General_Data.VLD_Info.sendOptionRecord == 0x1 )
    {
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_sig_req;
    }
    else if ( G_Reprog_General_Data.VLD_Info.sendOptionRecord == 0x0 )
    {
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_req;
    }
    else
    {
      /* 異常系確認ルート */
      /* SID 0x31 RoutineControl(checkMemorySoftwareData) ポジティブレスポンス受信完了 */
      G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x31_valid_req;
    }
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_valid_posres )
  {
    /* SID 0x31 RoutineControl(validApplication) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x11_ECUReset_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x31_valid_sig_posres )
  {
    /* SID 0x31 RoutineControl(validApplication) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x11_ECUReset_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x11_ECUReset_posres )
  {
    /* SID 0x11 ECUReset ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_SID_0x10_def_req;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_SID_0x10_def_posres )
  {
    /* SID 0x10 DiagnosticSessionControl(defaultSession) ポジティブレスポンス受信完了 */
    G_Reprog_General_Data.G_Info.pp1_process = E_PP1_Seqence_Normal_End;
  }
  else if ( G_Reprog_General_Data.G_Info.pp1_process == E_PP1_Seqence_Normal_End )
  {
    /* CANoeシナリオ正常終了後に謎のポジティブレスポンス受信 */
    /* 特に処理無し */
    Debug_Log_output("CANoe_Seqence_Response_Update: Unknown Positive Response.");
  }
  else
  {
    /* CANoe_Seqence_Direct_Updateで変な値にしていない限りエラーは発生しない */
    Error_Log_output("CANoe_Seqence_Response_Update: Illigal Seqence.");
  }

  return;
}


/// <General>
/* **************************************************** */
/* Function                                             */
/*  CANoe_Seqence_Direct_Update                         */
/* Discription                                          */
/*  シーケンス位置を指定したシーケンスに書き換える      */
/* IN :                                                 */
/*  seqence : 書き換えるシーケンス位置の値              */
/* OUT:                                                 */
/*  None                                                */
/* RET:                                                 */
/*  None                                                */
/* NOTE:                                                */
/*  None                                                */
/* **************************************************** */
void CANoe_Seqence_Direct_Update(int seqence)
{
  /* シーケンス位置を直接更新 */
  G_Reprog_General_Data.G_Info.pp1_process = seqence;

  return;
}


/// <General>
/* **************************************************** */
/* Function                                             */
/*  CANoe_Seqence_Get                                   */
/* Discription                                          */
/*  シーケンス位置を返す                                */
/* IN :                                                 */
/*  None                                                */
/* OUT:                                                 */
/*  None                                                */
/* RET:                                                 */
/*  シーケンス位置                                      */
/* NOTE:                                                */
/*  None                                                */
/* **************************************************** */
int CANoe_Seqence_Get(void)
{
  /* シーケンス位置を返す */
  return G_Reprog_General_Data.G_Info.pp1_process;
}


/// <General>
/* ***************************************************************** */
/* Function                                                          */
/*  CANoe_Seqence_Stop_Check                                         */
/* Discription                                                       */
/*  シナリオ停止対象SIDのリクエスト送信時にシナリオを停止する処理    */
/* IN :                                                              */
/*  None                                                             */
/* OUT:                                                              */
/*  None                                                             */
/* RET:                                                              */
/*  None                                                             */
/* NOTE:                                                             */
/*  止め方は単純にautorunのフラグを落とすだけ(再開させることも考慮)  */
/* ***************************************************************** */
void CANoe_Seqence_Stop_Check( void )
{
  int seqence;
  int bsc;

  /* 現在のシーケンス位置を取得*/
  seqence = CANoe_Seqence_Get();

  /* 停止シーケンス到達 */
  if( G_Reprog_General_Data.G_Info.stop_process == seqence )
  {
    /* SID2E(asfp)～SID31(checkAPL) */
    if( (seqence >= E_PP1_SID_0x2E_asfp_req) && (seqence < E_PP1_SID_0x31_valid_req) )
    {
      /* 終了対象LB到達 */
      if( G_Reprog_General_Data.G_Info.multiple_file_count == G_Reprog_General_Data.G_Info.stop_lb )
      {
        if( seqence == E_PP1_SID_0x36_dl_SBL_req )
        {
          if( G_Reprog_General_Data.T_Info_Erase.cnt[0] == G_Reprog_General_Data.G_Info.stop_bsc )
          {
            /* シーケンス停止 */
            G_Reprog_General_Data.G_Info.enable_autorun = 0;
          }
        }
        else if( seqence == E_PP1_SID_0x36_dl_APL_req )
        {
          if( G_Reprog_General_Data.T_Info_Reprog.cnt[0] == G_Reprog_General_Data.G_Info.stop_bsc )
          {
            /* シーケンス停止 */
            G_Reprog_General_Data.G_Info.enable_autorun = 0;
          }
        }
        else
        {
          /* シーケンス停止 */
          G_Reprog_General_Data.G_Info.enable_autorun = 0;
        }
      }
    }
    else
    {
      /* シーケンス停止 */
      G_Reprog_General_Data.G_Info.enable_autorun = 0;
    }
  }

  return;
}


/// <General>
/* **************************************************** */
/* Function                                             */
/*  CANoe_Seqence_Stop_Setting                          */
/* Discription                                          */
/*  シナリオ停止対象SID設定処理                         */
/* IN :                                                 */
/*  filename : 外部設定情報ファイル名                   */
/* OUT:                                                 */
/*  None                                                */
/* RET:                                                 */
/*  None                                                */
/* NOTE:                                                */
/*  None                                                */
/* **************************************************** */
void CANoe_Seqence_Stop_Setting( char filename[] )
{
  int stop_seqence;
  byte stop_lb;
  byte stop_bsc;
  long sid;
  long subfunc;
  long timing;

  stop_seqence = 0x0000FFFF;    /* 無効値 */
  stop_lb = 0x00;               /* 初回 */

  /* 外部設定情報(Reprog_Ext.ini)読み出し */
  /* sid (失敗時:無効値(0x0000FFFF)) */
  sid = getProfileInt("CANoeStop", "sid", 0x0000FFFF, filename);

  /* subfunc (失敗時:無効値(0x0000FFFF)) */
  subfunc = getProfileInt("CANoeStop", "subfunc", 0x0000FFFF, filename);

  /* timing (失敗時:SBL(0x00)) */
  timing = getProfileInt("CANoeStop", "timing", 0x00000000, filename);

  /* lb (失敗時:SBL(0x00)) */
  stop_lb = (byte)getProfileInt("CANoeStop", "lb", 0x00, filename);

  /* bsc (失敗時:0x01)) */
  stop_bsc = (byte)getProfileInt("CANoeStop", "bsc", 0x01, filename);

  /*======================================================*/
  /* | sid  | subfunc | timing | 停止契機サービス       | */
  /* |------|---------|--------|------------------------| */
  /* | 0x10 | 0x01    | －     | SID10 (default)        | */
  /* | 0x10 | 0x02    | －     | SID10 (programming)    | */
  /* | 0x11 | －      | －     | SID11                  | */
  /* | 0x27 | 0x01    | －     | SID27 (requestSeed)    | */
  /* | 0x27 | 0x02    | －     | SID27 (sendKey)        | */
  /* | 0x28 | －      | －     | SID28                  | */
  /* | 0x2E | 0xF160  | －     | SID2E (asfp )          | */
  /* | 0x2E | 0xF050  | －     | SID2E (Nonce)          | */
  /* | 0x31 | 0x01    | －     | SID31 (eraseMemory)    | */
  /* | 0x31 | 0x02    | 0x00   | SID31 (checkSBL：署名) | */
  /* | 0x31 | 0x02    | 0x01   | SID31 (checkAPL：署名) | */
  /* | 0x31 | 0x02    | 0x02   | SID31 (checkSBL：CRC)  | */
  /* | 0x31 | 0x02    | 0x03   | SID31 (checkAPL：CRC)  | */
  /* | 0x31 | 0x03    | －     | SID31 (valdAPL)        | */
  /* | 0x34 | －      | 0x00   | SID34 (SBL)            | */
  /* | 0x34 | －      | 0x01   | SID34 (APL)            | */
  /* | 0x36 | －      | 0x00   | SID36 (SBL)            | */
  /* | 0x36 | －      | 0x01   | SID36 (APL)            | */
  /* | 0x37 | －      | 0x00   | SID37 (SBL)            | */
  /* | 0x37 | －      | 0x01   | SID37 (APL)            | */
  /*======================================================*/
  /* stop_lb : 停止LogicalBlockのIndex番号                */
  /*           SID2E(asfp) ～ SID31(checkAPL) で指定可能  */
  /*           何回目のLB転送かを指定(0:1回目, 1:2回目…) */
  /* stop_bsc: 停止BlockSequenceCounter (SID36のみ)       */
  /*           指定bsc値の転送直前に停止                  */
  /*======================================================*/

  if( sid == 0x10 )
  {
    /* SID 0x10 DiagnosticSessionControl */
    subfunc = (subfunc & ~0x80);
    if( subfunc == 0x01 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x10_def;
    }
    else if( subfunc == 0x02 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x10_prog;
    }
    else if( subfunc == 0x03 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x10_ext;
    }
    else
    {
      Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x10 Sub_Function Invalid Value.");
    }
  }
  else if( sid == 0x11 )
  {
    /* SID 0x11 ECUReset */
    stop_seqence = E_CANoe_Stop_Sequence_SID_0x11;
  }
  else if( sid == 0x27 )
  {
    /* SID 0x27 SecurityAccess */
    subfunc = (subfunc & ~0x80);
    if( subfunc == 0x01 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x27_seed;
    }
    else if( subfunc == 0x02 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x27_key;
    }
    else
    {
      Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x27 Sub_Function Invalid Value.");
    }
  }
  else if( sid == 0x28 )
  {
    /* SID 0x28 CommunicationControl */
    stop_seqence = E_CANoe_Stop_Sequence_SID_0x28;
  }
  else if( sid == 0x3E )
  {
    /* SID 0x3E TesterPresent */
    /* TBD：現状0x3Eを設定しても停止機能は動作しない */
    stop_seqence = E_CANoe_Stop_Sequence_SID_0x3E;
  }
  else if( sid == 0x2E )
  {
    /* SID 0x2E WriteDataByIdentifier */
    /* subfunc を dataIdentifier として判定 */
    if( subfunc == 0xF050 )         /* Nonce */
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x2E_nonce;
    }
    else if( subfunc == 0xF160 )    /* Fingerprint */
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x2E_asfp;
    }
    else
    {
      Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x2E dataIdentifier Invalid Value.");
    }
  }
  else if( sid == 0x31 )
  {
    /* SID 0x31 RoutineControl */
    /* subfunc を RID判別情報として判定 */
    if( subfunc == 0x01 )       /* eraseMemory */
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_erase;
    }
    else if( subfunc == 0x02 )  /* checkMemory */
    {
      /* timing をチェック種別として判定 */
      if( timing == 0x00 )      /* checkSBL：署名 */
      {
        stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_SBL_chk_sign;
      }
      else if( timing == 0x01 ) /* checkAPL：署名 */
      {
        stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_APL_chk_sign;
      }
      else if( timing == 0x02 ) /* checkSBL：CRC */
      {
        stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_SBL_chk_crc;
      }
      else if( timing == 0x03 ) /* checkAPL：CRC */
      {
        stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_APL_chk_crc;
      }
      else if( timing == 0x04 ) /* checkSBL：CMAC */
      {
        stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_SBL_chk_cmac;
      }
      else if( timing == 0x05 ) /* checkAPL：CMAC */
      {
        stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_APL_chk_cmac;
      }
      else
      {
        Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x31 timing Invalid Value.");
      }
    }
    else if( subfunc == 0x03 )  /* validateApplication */
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x31_validate;
    }
    else
    {
      Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x31 Sub_Function Invalid Value.");
    }
  }
  else if( sid == 0x34 )
  {
    /* SID 0x34 RequestDownload */
    /* timing を SBL/APL判別情報として判定 */
    if( timing == 0x00 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x34_SBL;
    }
    else if( timing == 0x01 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x34_APL;
    }
    else
    {
      Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x34 timing Invalid Value.");
    }
  }
  else if( sid == 0x36 )
  {
    /* SID 0x36 TransferData */
    /* timing を SBL/APL判別情報として判定 */
    if( timing == 0x00 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x36_SBL;
    }
    else if( timing == 0x01 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x36_APL;
    }
    else
    {
      Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x36 timing Invalid Value.");
    }
  }
  else if( sid == 0x37 )
  {
    /* SID 0x37 RequestTransferExit */
    /* timing を SBL/APL判別情報として判定 */
    if( timing == 0x00 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x37_SBL;
    }
    else if( timing == 0x01 )
    {
      stop_seqence = E_CANoe_Stop_Sequence_SID_0x37_APL;
    }
    else
    {
      Error_Log_output("CANoe_Seqence_Stop_Setting: SID 0x37 timing Invalid Value.");
    }
  }
  else
  {
    /* 該当するSIDがなかったので、CANoeシナリオの停止機能は未使用と判断 */
    /* デバッグ表示 */
    Debug_Log_output("CANoe Senario Stop Function Disabled");
  }

  /* CANoeシナリオの停止機能の対象のSIDのシーケンス番号を設定 */
  G_Reprog_General_Data.G_Info.stop_process = stop_seqence;
  G_Reprog_General_Data.G_Info.stop_lb = stop_lb;
  G_Reprog_General_Data.G_Info.stop_bsc = stop_bsc;

  return;
}


/// <General>
/* ******************************************************** */
/* Function                                                 */
/*  CANoe_APLStart_Waittime                                 */
/* Discription                                              */
/*  APL要求起動時に、初回のリクエストの遅延タイマに設定する */
/*  Wait値を取得する処理                                    */
/* IN :                                                     */
/*  filename : 外部設定情報ファイル名                       */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  None                                                    */
/* NOTE:                                                    */
/*  読み出し失敗時はデフォルト値()を設定                    */
/* ******************************************************** */
void CANoe_APLStart_Waittime( char filename[] )
{
  /* 外部設定情報から遅延タイマ値を読み出し */
  /* 読み出し失敗時はデフォルト値(10ミリ秒)を使用する設定 */
  G_Reprog_General_Data.G_Info.aplstart_wait = getProfileInt("APLstart", "wait", 10, filename);

  return;
}

/// <General>
/* ********************************************************* */
/* Function                                                  */
/*  Request_default_timeout                                  */
/* Discription                                               */
/*  全リクエストに対するタイムアウト時に呼び出すハンドラ設定 */
/* IN :                                                      */
/*  None                                                     */
/* OUT:                                                      */
/*  None                                                     */
/* RET:                                                      */
/*  diagSetTimeoutHandler()の処理結果                        */
/* NOTE:                                                     */
/*  タイムアウト値はデフォルトの1000msのままとなるので、     */
/*  必要であればdiagSetTimeout()で再設定すること             */
/* ********************************************************* */
int Request_setup_timeout_handler(char handler_name[])
{
  /* 戻り値 */
  int ret;

  do
  {
    /* SID 0x10 DiagnosticSessionControl用定義 */
    ret = diagSetTimeoutHandler(G_DiagnosticSessionControl_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_DiagnosticSessionControl_req_01");
      break;
    }
    ret = diagSetTimeoutHandler(G_DiagnosticSessionControl_req_02, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_DiagnosticSessionControl_req_02");
      break;
    }
    ret = diagSetTimeoutHandler(G_DiagnosticSessionControl_req_03, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_DiagnosticSessionControl_req_03");
      break;
    }
    ret = diagSetTimeoutHandler(G_DiagnosticSessionControl_req_06, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_DiagnosticSessionControl_req_06");
      break;
    }
    /* SID 0x11 EcuReset用定義 */
    ret = diagSetTimeoutHandler(G_EcuReset_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_EcuReset_req_01");
      break;
    }

    /* SID 0x22 ReadDataByIdentifier用定義 */
    ret = diagSetTimeoutHandler(G_ReadDataByIdentifier_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_ReadDataByIdentifier_req_01");
      break;
    }
    ret = diagSetTimeoutHandler(G_ReadDataByIdentifier_req_02, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_ReadDataByIdentifier_req_02");
      break;
    }

    /* SID 0x27 SecurityAccess用定義 */
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_01, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_01");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_02, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_02");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_03, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_03");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_04, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_04");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_05, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_05");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_06, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_06");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_07, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_07");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_08, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_08");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_09, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_09");
      break;
    }
    ret = diagSetTimeoutHandler(G_SecurityAccess_req_10, handler_name);
    if(ret != 0)
    {
      /* ハンドラ設定失敗 */
      /* デバッグ表示 */
      Error_Log_output("Request_setup_timeout_handler:diagSetTimeoutHandler error. for G_SecurityAccess_req_10");
