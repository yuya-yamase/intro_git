/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long SecurityAccess_res_distribution( diagResponse * res_msg )
{
  /* 戻り値 */
  int ret;

  /* SecurityAccessのポジティブレスポンス受信時は処理無し */
  ret = E_Return_OK;
  
  return ret;
}


/// <SecurityAccess>
/* ******************************************************** */
/* Function                                                 */
/*  SecurityAccess_init                                     */
/* Discription                                              */
/*  外部設定情報ファイルからツール認証キーを読み出す        */
/* IN :                                                     */
/*  filename : 外部設定情報ファイル名                       */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  E_Return_OK 　　　　　　　　　　　　　　　              */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long SecurityAccess_init( char filename[] )
{
  /* 戻り値 */
  int ret;
  int cnt;
  int tool_index;
  int buff_index;
  char read_buff[16*5];
  
  /* ファイル読み出し(ツール認証キー) */
  /* ここでは文字列型として読み出す */
  ret = getProfileString( "SecurityAccess", "ToolAuthKey", 
          "0x00,0x11,0x22,0x33,0x44,0x55,0x66,0x77,0x88,0x99,0xAA,0xBB,0xCC,0xDD,0xEE,0xFF",
          read_buff, elcount(read_buff), filename );
  if( ret <= 0 || ret > (16*5) )
  {
    /* ツール認証キー読み出し失敗 */
    Error_Log_output("SecurityAccess_init: Read ToolAuthKey Error.");
  }

  /* 2バイト*16個のツール認証キーを設定するまでループ */
  for ( cnt = 0; cnt < 16 ; cnt++ )
  {
    /* ツール認証キーのindex値を設定 */
    tool_index = cnt * 2;
    /* 読み出したバッファのindex値を設定*/
    buff_index = (cnt * 5) + 2;
      
    /* ファイルから読み出したツール認証キーを2バイト毎に管理情報G_Reprog_General_Dataに設定　*/
    G_Reprog_General_Data.S_Info.ToolAuthKey[tool_index] = read_buff[buff_index];      
    G_Reprog_General_Data.S_Info.ToolAuthKey[tool_index+1] = read_buff[buff_index+1];
  }
  
  return ret;
}