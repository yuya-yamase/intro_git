}


/// <RoutineControl>
/* ******************************************************** */
/* Function                                                 */
/*  RoutineControl_set_request_check_msd_cmac               */
/* Discription                                              */
/*  routineIdentifierとCMACを                               */
/*  TransferDataリクエストメッセージに設定する              */
/* IN :                                                     */
/*  type    : E_RoutineControl_Type_Numに相当する値         */
/*  req_msg : diagRequest型のリクエストメッセージ           */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSetParameterRaw()の処理結果 または E_Return_OK      */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long RoutineControl_set_request_check_msd_cmac( dword type, diagRequest * req_msg )
{
  /* 戻り値 */
  int ret;
  int cnt;
  byte checkTypeIdentifier_buff[1];
  byte checkDataLength_buff[2];
  byte checkData_buff[E_routineControlOptionRecord_SIGNATURE];

  checkTypeIdentifier_buff[0] = 0x02;
  checkDataLength_buff[0] = 0x00;
  checkDataLength_buff[1] = 0x10;

  /* checkData初期化 */
  for( cnt = 0; cnt < E_routineControlOptionRecord_SIGNATURE; cnt++ )
  {
    checkData_buff[cnt] = 0xCC;
  }

  for( cnt = 0; cnt < E_routineControlOptionRecord_CMAC; cnt++ )
  {
    checkData_buff[cnt] = G_Reprog_General_Data.T_Info_Reprog.checkData[cnt];
  }

  /* 「書換えデータ」かを判定 */
  if( type == E_RoutineControl_Type_Reprog )
  {
    /* RoutineControlのリクエストオブジェクトにcheckTypeIdentifierを設定 */
    ret = diagSetParameterRaw(req_msg, "checkTypeIdentifier",
                              checkTypeIdentifier_buff,
                              elcount(checkTypeIdentifier_buff));

    /* RoutineControlのリクエストオブジェクトにcheckDataLengthを設定 */
    ret = diagSetParameterRaw(req_msg, "checkDataLength",
                              checkDataLength_buff,
                              elcount(checkDataLength_buff));

    /* RoutineControlのリクエストオブジェクトに新たなcheckDataを設定 */
    /* 事前に読み出したバッファを設定する方式 */
    ret = diagSetParameterRaw(req_msg, "checkData",
                              checkData_buff,
                              elcount(checkData_buff));

    diagResize( req_msg, 23 );
  }
  else
  {
    /* このルートは使用されない */
    Error_Log_output("RoutineControl_set_request_check_msd_cmac: Illiegal Type.");
  }

  /* 戻り値の判断は上位関数で実施 */
  return ret;
}


/// <RoutineControl>
/* ******************************************************** */
/* Function                                                 */
/*  RoutineControl_set_request_check_msd_crc                */
/* Discription                                              */
/*  routineIdentifierとCRCを                                */
/*  TransferDataリクエストメッセージに設定する              */
/* IN :                                                     */
/*  type    : E_RoutineControl_Type_Numに相当する値         */
/*  req_msg : diagRequest型のリクエストメッセージ           */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSetParameterRaw()の処理結果 または E_Return_OK      */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long RoutineControl_set_request_check_msd_crc( dword type, diagRequest * req_msg, struct S_TransferData_info T_Info )
{
  /* 戻り値 */
  int ret;
  int cnt;
  int checkDataLength;
  byte checkTypeIdentifier_buff[1];
  byte checkDataLength_buff[2];
  byte checkData_buff[E_routineControlOptionRecord_SIGNATURE];

  checkTypeIdentifier_buff[0] = 0x02;
  checkDataLength_buff[0] = T_Info.checkDataLength[0];
  checkDataLength_buff[1] = T_Info.checkDataLength[1];

  /* checkData初期化 */
  for( cnt = 0; cnt < E_routineControlOptionRecord_SIGNATURE; cnt++ )
  {
    checkData_buff[cnt] = 0xCC;
  }

  for( cnt = 0; cnt < E_routineControlOptionRecord_CRC; cnt++ )
  {
    checkData_buff[cnt] = G_Reprog_General_Data.T_Info_Reprog.checkData[cnt];
  }

  /* 「書換えデータ」かを判定 */
  if( type == E_RoutineControl_Type_Reprog )
  {
    /* RoutineControlのリクエストオブジェクトにcheckTypeIdentifierを設定 */
    ret = diagSetParameterRaw(req_msg, "checkTypeIdentifier",
                              checkTypeIdentifier_buff,
                              elcount(checkTypeIdentifier_buff));

    /* RoutineControlのリクエストオブジェクトにcheckDataLengthを設定 */
    ret = diagSetParameterRaw(req_msg, "checkDataLength",
                              checkDataLength_buff,
                              elcount(checkDataLength_buff));

    /* RoutineControlのリクエストオブジェクトにcheckDataを設定 */
    /* 事前に読み出したバッファを設定する方式 */
    ret = diagSetParameterRaw(req_msg, "checkData",
                              checkData_buff,
                              elcount(checkData_buff));

    checkDataLength = T_Info.checkDataLength[0] * 256 + T_Info.checkDataLength[1];
    diagResize( req_msg, 7+checkDataLength );
  }
  else
  {
    /* このルートは使用されない */
    Error_Log_output("RoutineControl_set_request_check_msd_crc: Illiegal Type.");
  }

  /* 戻り値の判断は上位関数で実施 */
  return ret;
}


/// <RoutineControl>
/* ******************************************************** */
/* Function                                                 */
/*  RoutineControl_set_request_eraseMemory                  */
/* Discription                                              */
/*  memoryAddressとmemorySizeを                             */
/*  RoutineControlリクエストメッセージに設定する            */
/* IN :                                                     */
/*  req_msg : diagRequest型のリクエストメッセージ           */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSetParameterRaw()の処理結果 または E_Return_OK      */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long RoutineControl_set_request_eraseMemory( diagRequest * req_msg )
{
  /* 戻り値 */
  int ret;

  /* RoutineControlのリクエストオブジェクトに新たなmemoryAddressを設定 */
  /* 事前に読み出したバッファを設定する方式 */
  ret = diagSetParameterRaw(req_msg, "memoryAddress",
                            G_Reprog_General_Data.T_Info_Reprog.address,
                            elcount(G_Reprog_General_Data.T_Info_Reprog.address));
  if ( ret == E_Return_OK )
  {
    /* RoutineControlのリクエストオブジェクトに新たなmemorySizeを設定 */
    /* 事前に読み出したバッファを設定する方式 */
    ret = diagSetParameterRaw(req_msg, "memorySize",
                              G_Reprog_General_Data.T_Info_Reprog.size,
                              elcount(G_Reprog_General_Data.T_Info_Reprog.size));
  }

  /* 戻り値の判断は上位関数で実施 */
  return ret;
}

/// <RoutineControl>
/* ******************************************************** */
/* Function                                                 */
/*  RoutineControl_set_request_validApplication_signature   */
/* Discription                                              */
/*  routineIdentifierとSignatureを                          */
/*  TransferDataリクエストメッセージに設定する              */
/* IN :                                                     */
/*  type    : E_RoutineControl_Type_Numに相当する値         */
/*  req_msg : diagRequest型のリクエストメッセージ           */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSetParameterRaw()の処理結果 または E_Return_OK      */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long RoutineControl_set_request_validApplication_signature( dword type, diagRequest * req_msg, struct S_ValidateApplication_info T_Info )
{
  /* 戻り値 */
  int ret;
  int checkDataLength;
  byte checkTypeIdentifier_buff[1];
  byte checkDataLength_buff[2];

  checkTypeIdentifier_buff[0] = 0x01;
  checkDataLength_buff[0] = T_Info.checkDataLength[0];
  checkDataLength_buff[1] = T_Info.checkDataLength[1];

  /* 「種別指定無し」かを判定 */
  if( type == E_RoutineControl_Type_Common )
  {
    /* RoutineControlのリクエストオブジェクトにcheckTypeIdentifierを設定 */
    ret = diagSetParameterRaw(req_msg, "checkTypeIdentifier",
                              checkTypeIdentifier_buff,
                              elcount(checkTypeIdentifier_buff));

    /* RoutineControlのリクエストオブジェクトにcheckDataLengthを設定 */
    ret = diagSetParameterRaw(req_msg, "checkDataLength",
                              checkDataLength_buff,
                              elcount(checkDataLength_buff));

    /* RoutineControlのリクエストオブジェクトに新たなcheckDataを設定 */
    /* 事前に読み出したバッファを設定する方式 */
    ret = diagSetParameterRaw(req_msg, "checkData",
                              G_Reprog_General_Data.VLD_Info.checkData,
                              elcount(G_Reprog_General_Data.VLD_Info.checkData));

    checkDataLength = T_Info.checkDataLength[0] * 256 + T_Info.checkDataLength[1];
    diagResize( req_msg, 7+checkDataLength );
  }
  else
  {
    /* このルートは使用されない */
    Error_Log_output("RoutineControl_set_request_validApplication_signature: Illiegal Type.");
  }

  /* 戻り値の判断は上位関数で実施 */
  return ret;
}

/// <RoutineControl>
/* ******************************************************** */
/* Function                                                 */
/*  RoutineControl_set_request_validApplication             */
/* Discription                                              */
/* routineIdentifierとCRCを                                 */
/*  TransferDataリクエストメッセージに設定する              */
/* IN :                                                     */
/*  type    : E_RoutineControl_Type_Numに相当する値         */
/*  req_msg : diagRequest型のリクエストメッセージ           */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSetParameterRaw()の処理結果 または E_Return_OK      */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long RoutineControl_set_request_validApplication( dword type, diagRequest * req_msg, struct S_ValidateApplication_info T_Info )
{
  /* 戻り値 */
  int ret;
  int cnt;
  byte checkTypeIdentifier_buff[1];
  byte checkDataLength_buff[2];
  byte checkData_buff[E_routineControlOptionRecord_SIGNATURE];

  checkTypeIdentifier_buff[0] = 0xCC;
  checkDataLength_buff[0] = 0xCC;
  checkDataLength_buff[1] = 0xCC;

  /* checkData初期化 */
  for( cnt = 0; cnt < E_routineControlOptionRecord_SIGNATURE; cnt++ )
  {
    checkData_buff[cnt] = 0xCC;
  }

  /* 「種別指定無し」かを判定 */
  if( type == E_RoutineControl_Type_Common )
  {
    /* RoutineControlのリクエストオブジェクトにcheckTypeIdentifierを設定 */
    ret = diagSetParameterRaw(req_msg, "checkTypeIdentifier",
                              checkTypeIdentifier_buff,
                              elcount(checkTypeIdentifier_buff));

    /* RoutineControlのリクエストオブジェクトにcheckDataLengthを設定 */
    ret = diagSetParameterRaw(req_msg, "checkDataLength",
                              checkDataLength_buff,
                              elcount(checkDataLength_buff));

    /* RoutineControlのリクエストオブジェクトにcheckDataを設定 */
    /* 事前に読み出したバッファを設定する方式 */
    ret = diagSetParameterRaw(req_msg, "checkData",
                              checkData_buff,
                              elcount(checkData_buff));

    diagResize( req_msg, 4 );
  }
  else
  {
    /* このルートは使用されない */
    Error_Log_output("RoutineControl_set_request_validApplication: Illiegal Type.");
  }

  /* 戻り値の判断は上位関数で実施 */
  return ret;
}

/// <RoutineControl>
/* ******************************************************** */
/* Function                                                 */
/*  ValidateApplication_init                                */
/* Discription                                              */
/*  外部設定情報ファイルを読み出してcheckTypeIdentifierと   */
/*  checkDataを設定する                                     */
/* IN :                                                     */
/*  filename : 外部設定情報ファイル名                       */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  E_Return_OK                                             */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */

int ValidateApplication_init( char filename[] ){
  char vldcsvFilePath[128];
  char vldsigFilePath[128];
  int canOpenFile;
  dword vldcsvHandle;
  dword vldsigHandle;

  int num_ValidateApplication_info_All_Element = 1;
  int rowCount;
  int read_cnt;
  long oldOffset;
  long newOffset;
  char buff[1024];
  char tmp_checkTypeIdentifier[5];
  char tmp_sendOptionRecord[4];
  struct S_ValidateApplication_info Work_VLD_Info;
  int checkDataLength;
  int EOF = 0;
  byte read_buff[E_routineControlOptionRecord_SIGNATURE];


  /* Reprog_Ext.iniからsendOptionRecordを読み込んで構造体に格納 */
  canOpenFile = getProfileString("ValidateApplication", "sendOptionRecord", "0x0", tmp_sendOptionRecord, elcount(tmp_sendOptionRecord), filename);
  if( canOpenFile <= 0 ){
    Error_Log_output("ValidateApplication_init: Ext File Read Error.");
    return (int) E_Return_FILEOPEN_NG;
  }
  Work_VLD_Info.sendOptionRecord = atol(tmp_sendOptionRecord);


  /* Reprog_Ext.iniからVLD.csvのファイルパスを読み込む */
  canOpenFile = getProfileString("ValidateApplication", "VLDSettingFile", "DLfile\\VLD.csv", vldcsvFilePath, elcount(vldcsvFilePath), filename);
  if( canOpenFile <= 0 ){
    Error_Log_output("ValidateApplication_init: Ext File Read Error.");
    return (int) E_Return_FILEOPEN_NG;
  }

  /* VLD.csvを開く */
  vldcsvHandle = openFileRead(vldcsvFilePath, E_Openfile_mode_text);
  if ( vldcsvHandle == 0 ){
    Error_Log_output("ValidateApplication_init: VLD CSV File Open Error.");
    return (int) E_Return_FILEOPEN_NG;
  }

  for( rowCount = 0; rowCount < num_ValidateApplication_info_All_Element+1; rowCount++){
    /* ファイル終端 */
    if ( fileGetStringSZ(buff, elCount(buff), vldcsvHandle) == EOF ){
      break;
    }

    /* 読み出したデータに,以外何も設定されていなかったら読み出し終了する */
    if( strncmp(buff, ",", elcount(buff)) == 0 )
    {
      break;
    }

    /* 見出し行を読み捨てる */
    if ( rowCount == 0){
      continue;
    }

    /* バッファのオフセット値をクリア */
    oldOffset = 0;
    newOffset = 0;

    /* checkTypeIdentifierを読み出す */
    newOffset = strstr_off(buff, oldOffset, ",");
    strncpy( tmp_checkTypeIdentifier, buff, (newOffset - oldOffset + 1));
    Work_VLD_Info.checkTypeIdentifier = atol(tmp_checkTypeIdentifier);
    oldOffset = newOffset + 1;

    /* validateのsignatureファイルパスを読み出す */
    newOffset = strlen(buff);
    substr_cpy_off(vldsigFilePath, 0, buff, oldOffset,(newOffset - oldOffset), elcount(vldsigFilePath));

    /* signatureファイルを開く*/
    vldsigHandle = openFileRead( vldsigFilePath, E_Openfile_mode_binary );
    if ( vldsigHandle == 0 ){
      Error_Log_output("ValidateApplication_init: VLD checkData File Open Error.");
      return (int) E_Return_FILEOPEN_NG;
    }

    /* checkdataの長さと中身をsignatureファイルから読み出す*/
    checkDataLength = fileGetBinaryBlock( Work_VLD_Info.checkData, elcount(read_buff), vldsigHandle );
    if ( checkDataLength == 0 ){
      Error_Log_output("ValidateApplication_init: VLD checkData File Read Error.");
      return (int) E_Return_FILEOPEN_NG;
    }
    Work_VLD_Info.checkDataLength[0] = (byte)((checkDataLength & 0x0000FF00) >> 8);
    Work_VLD_Info.checkDataLength[1] = (byte)(checkDataLength & (0x000000FF));

    /* signatureファイルClose */
    if ( fileClose(vldsigHandle) == 0 ){
      Error_Log_output("ValidateApplication_init: fileClose error(checkData)");
      return (int) E_Return_FILECLOSE_NG;
    }

    /* 作業用の構造体からG_Reprog_General_Dataに再配置 */
    G_Reprog_General_Data.VLD_Info.sendOptionRecord = Work_VLD_Info.sendOptionRecord;
    G_Reprog_General_Data.VLD_Info.checkTypeIdentifier = Work_VLD_Info.checkTypeIdentifier;
    for( read_cnt = 0; read_cnt < E_routineControlOptionRecord_checkDataLength; read_cnt++ )
    {
        G_Reprog_General_Data.VLD_Info.checkDataLength[read_cnt] = Work_VLD_Info.checkDataLength[read_cnt];
    }
    for( read_cnt = 0; read_cnt < E_routineControlOptionRecord_SIGNATURE; read_cnt++ )
    {
      G_Reprog_General_Data.VLD_Info.checkData[read_cnt] = Work_VLD_Info.checkData[read_cnt];
    }
  }

  Debug_Log_output("ValidateApplication_init:Read Complete!");

  /* CSVファイルClose */
  if ( fileClose(vldcsvHandle) == 0 ){
    Error_Log_output("ValidateApplication_init: fileClose error");
    return (int) E_Return_FILECLOSE_NG;
  }
  return (int) E_Return_OK;
}
