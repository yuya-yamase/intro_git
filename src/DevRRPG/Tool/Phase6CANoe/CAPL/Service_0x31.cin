                              G_Reprog_General_Data.T_Info_Reprog.checkData,
                              elcount(G_Reprog_General_Data.T_Info_Reprog.checkData));

    checkDataLength = T_Info.checkDataLength[0] * 256 + T_Info.checkDataLength[1];
    diagResize( req_msg, 7+checkDataLength );
  }
  else
  {
    /* このルートは使用されない */
    Error_Log_output("RoutineControl_set_request_check_msd_signature: Illiegal Type.");
  }

  /* 戻り値の判断は上位関数で実施 */
