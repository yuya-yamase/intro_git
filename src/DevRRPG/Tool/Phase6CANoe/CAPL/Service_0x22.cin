/// <ReadDataByIdentifier>
/* ******************************************************** */
/* Function                                                 */
/*  ReadDataByIdentifier_Nonce_request_01_send              */
/* Discription                                              */
/*  Send Request Sid0x22 [ReadDataByIdentifier]             */
/* IN :                                                     */
/*  sprmib : SPRMIB有効フラグ(E_FLAG_ON=ならSPRMIBを付与)   */
/* OUT:                                                     */
/*  None                                                    */
/* RET:                                                     */
/*  diagSendRequest()の処理結果 または                      */
/*  E_Return_SPRMIB_Set_NG                                  */
/* NOTE:                                                    */
/*  None                                                    */
/* ******************************************************** */
long ReadDataByIdentifier_Nonce_request_01_send( long sprmib )
{
  /* 戻り値 */
  int ret;

  /* 読み出し結果がレスポンスとして返ってくる以上、SPRMIBを設定するケースは存在しないはず */
  if( sprmib == E_Flag_OFF )
  {
    /* リクエスト送信 */
    ret = diagSendRequest(G_ReadDataByIdentifier_req_09);
  }
  else
  {
    /* SPRMIBの設定失敗 */
    ret = E_Return_SPRMIB_Set_NG;
  }
  
  /* リクエスト送信の戻り値を返す */
  return ret;   
}

