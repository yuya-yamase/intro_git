/******************************************************************************/
/* Function Name | Shutdown_ResetMcuRam                                       */
/* Description   | Reset MCU by software reset register(RAM function)         */
/* Preconditions |                                                            */
/* Parameters    | None                                                       */
/* Return Value  | None                                                       */
/* Notes         | - This function will never return.                         */
/*               | - This function is same as Shutdown_ResetMcu, but execute  */
/*               |   on RAM.                                                  */
/******************************************************************************/
    .section ".P_RAM_2ND", "ax"
    .align 2
    .globl _Shutdown_ResetMcuRam
_Shutdown_ResetMcuRam:
    /* Enable write to protected register */
    mov     SHUTDOWN_VAL_KCPROT_ENABLE, r12
    mov     SHUTDOWN_REG_RESKCPROT0, r13
    st.w    r12, 0[r13]

    /* Set SWSRESA register to reset */
    mov     SHUTDOWN_VAL_RESET_SWSRESA_ON, r12
    mov     SHUTDOWN_REG_RESET_SWSRESA, r13
    st.w    r12, 0[r13]

    /* Disable write to protected register */
    mov     SHUTDOWN_VAL_KCPROT_DISABLE, r12
    mov     SHUTDOWN_REG_RESKCPROT0, r13
    st.w    r12, 0[r13]

SHUTDOWN_RESET_RAM_END:
    br      SHUTDOWN_RESET_RAM_END


