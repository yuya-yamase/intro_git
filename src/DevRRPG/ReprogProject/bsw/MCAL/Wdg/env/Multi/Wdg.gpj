#!gbuild
[Library]
	-I../../inc
	-Mn
	-map
	-object_dir=$TOP_DIR/bsw/MCAL/Wdg/obj
	{optgroup=GhsCommonOptions} -o $TOP_DIR/bsw/MCAL/Wdg/obj/Wdg.lib

{streq(PLATFORM_NAME, RH850, TraveoII)} ../../usr/micon/$MICON_NAME/Wdg.c

{streq(PLATFORM_NAME, TC3XX)} ../../usr/micon/$PLATFORM_NAME/Wdg.c
