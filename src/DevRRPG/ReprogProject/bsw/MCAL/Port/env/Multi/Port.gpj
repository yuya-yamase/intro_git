#!gbuild
[Library]
	-I../../inc
	-Mn
	-map
	-object_dir=$TOP_DIR/bsw/MCAL/Port/obj
	{optgroup=GhsCommonOptions} -o $TOP_DIR/bsw/MCAL/Port/obj/Port.lib

{streq(PLATFORM_NAME, RH850, TraveoII)} ../../usr/micon/$MICON_NAME/Port.c

{streq(PLATFORM_NAME, TC3XX)} ../../usr/micon/$PLATFORM_NAME/Port.c
