#!gbuild
[Relocatable Object]
	-Mn
	-map
	-object_dir=$TOP_DIR/bsw/MCAL/Mcu/obj
	{optgroup=GhsCommonOptions} -o $TOP_DIR/bsw/MCAL/Mcu/obj/Mcu_cfg.rel.o

{streq(PLATFORM_NAME, RH850, TraveoII)} ../../cfg/micon/$MICON_NAME/Mcu_Cfg.c

{streq(PLATFORM_NAME, TC3XX)} ../../cfg/micon/$PLATFORM_NAME/Mcu_Cfg.c
