/****************************************************************************
[ v850_user_exc_entry_ghs.850 ] - V850 exception handler for non-OS sample
****************************************************************************/

    #define _in_asm_source_

#define OS_START_SEC_CODE_SHARED
#include "Os_MemMap.h"

 /*---------------------------------------------------------------------------
  _mcos_v850_nonos_feexc_entry
      Exception entry for non-OS FE level
      This function is registered in the exception vector(EBASE) by user. 
 ---------------------------------------------------------------------------*/
    .type   _mcos_v850_nonos_feexc_entry, $function
    .global _mcos_v850_nonos_feexc_entry

_mcos_v850_nonos_feexc_entry:
    /* to be implemented by user */
    br  _mcos_v850_nonos_feexc_entry
    .size   _mcos_v850_nonos_feexc_entry, .-_mcos_v850_nonos_feexc_entry

 /*---------------------------------------------------------------------------
  _mcos_v850_nonos_eiexc_entry
      Exception entry for non-OS EI level
      This function is registered in the exception vector(EBASE) by user. 
 ---------------------------------------------------------------------------*/
    .type   _mcos_v850_nonos_eiexc_entry, $function
    .global _mcos_v850_nonos_eiexc_entry

_mcos_v850_nonos_eiexc_entry:
    /* to be implemented by user */
    br  _mcos_v850_nonos_eiexc_entry
    .size   _mcos_v850_nonos_eiexc_entry, .-_mcos_v850_nonos_eiexc_entry

 /*---------------------------------------------------------------------------
  _mcos_v850_undefint_entry
      Undefined EIINTn entry
      This function is registered in the interrupt vector(INTBP) by OS. 
 ---------------------------------------------------------------------------*/
    .type   _mcos_v850_undefint_entry, $function
    .global _mcos_v850_undefint_entry

_mcos_v850_undefint_entry:
    /* to be implemented by user */
    br  _mcos_v850_undefint_entry
    .size   _mcos_v850_undefint_entry, .-_mcos_v850_undefint_entry

#define OS_STOP_SEC_CODE_SHARED
#include "Os_MemMap.h"
