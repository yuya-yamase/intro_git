/****************************************************************************
[ehvm_VWdt_ghs.850] - EHVM assembly implements for v850
****************************************************************************/
    .file "ehvm_VWdt_ghs.850"

#define VWDT_SETMODE_FUNC    2
#define VWDT_SETTRIGGER_FUNC 3



    .global _hvm_VWdt_SetMode_hvc
    .type   _hvm_VWdt_SetMode_hvc, @function
_hvm_VWdt_SetMode_hvc:
    pushsp lp - lp                              /* lp */
    pushsp r12 - r16
    pushsp r1 - r1
    mov VWDT_SETMODE_FUNC, r12  /* set functionID */
    mov r6, r13  /* set DeviceIndex */
    mov r7, r14  /* set VWdtMode */
    hvtrap 0x00  /* exec Hyper Visor Call */
    mov r1, r10  /* set return value */
    popsp  r1 - r1
    popsp  r12 - r16
    popsp  lp - lp                              /* lp */
    jmp    lp

    .global _hvm_VWdt_SetTriggerCondition_hvc
    .type   _hvm_VWdt_SetTriggerCondition_hvc, @function
_hvm_VWdt_SetTriggerCondition_hvc:
    pushsp lp - lp                              /* lp */
    pushsp r12 - r14
    pushsp r1 - r1
    mov VWDT_SETTRIGGER_FUNC, r12  /* set functionID */
    mov r6, r13  /* set DeviceIndex */
    mov r7, r14  /* set Timeout */
    hvtrap 0x00  /* exec Hyper Visor Call */
    mov r1, r10  /* set return value */
    popsp  r1 - r1
    popsp  r12 - r14
    popsp  lp - lp                              /* lp */
    jmp    lp

