primaryTarget=v800_standalone.tgt
[Program]
    :optionsFile=../ghs_ccal_rh850g4mh.opt
    -object_dir=obj/ehvm

    -o dst/ehvm.elf

    :macro=GCLI_PAR="0x003c0000 0x003fffff 0xff -start 0x003c0000 -end 0x003fffff"
    :macro=GCLI_MOT="gsrec -sort -S3 -noS5 -bytes 16 -pad1"
    :macro=GCLI_BIN="gmemfile -fill1"

    :postexec="${GCLI_MOT} ${GCLI_PAR}                     -o dst/ehvm_ac.mot dst/ehvm.elf"
    :postexec="${GCLI_MOT} ${GCLI_PAR} -romaddr 0x023c0000 -o dst/ehvm_bd.mot dst/ehvm.elf"
    :postexec="${GCLI_BIN} ${GCLI_PAR}                     -o dst/ehvm.bin dst/ehvm.elf"

