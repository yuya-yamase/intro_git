#!gbuild
gbuildDir=C:\GHS\RH850_V.R9144\comp_201715
primaryTarget=v800_standalone.tgt
[Program]
    :optionsFile=../ghs_ccal_rh850g4mh.opt
    -object_dir=obj/ehvm

    # --------------------------------------
    # EHVM/Hv Options
    # --------------------------------------
    -DEHVM_CORE_NUM=4U
    -DEHVM_CORE_NUM_2=2U
    -DEHVM_CORE_NUM_4=4U
    -DEHVM_TARGET_U2A
    # --------------------------------------
    # --------------------------------------
    # System/22SS Options
    # --------------------------------------
    -DECU_HOST
    # --------------------------------------

    {isdefined(__GMM_AIP_THROUGHPUT__)} -D__AIP_THROUGHPUT__=${__GMM_AIP_THROUGHPUT__}

    -o dst/ehvm.elf


    :macro=GCLI_PAR="0x003c0000 0x003fffff 0xff -start 0x003c0000 -end 0x003fffff"
    :macro=GCLI_MOT="gsrec -sort -S3 -noS5 -bytes 16 -pad1"
    :macro=GCLI_BIN="gmemfile -fill1"

    :postexec="${GCLI_MOT} ${GCLI_PAR}                     -o dst/ehvm_ac.mot dst/ehvm.elf"
    :postexec="${GCLI_MOT} ${GCLI_PAR} -romaddr 0x023c0000 -o dst/ehvm_bd.mot dst/ehvm.elf"
    :postexec="${GCLI_BIN} ${GCLI_PAR}                     -o dst/ehvm.bin dst/ehvm.elf"

# ----------------------------------------------------------------------------------------------------------------------------------
# Subprojects : C Compiler/Assembler/Linker Options
# ----------------------------------------------------------------------------------------------------------------------------------
    :optionsFile=sub/ehvm_bsw.opt

# ----------------------------------------------------------------------------------------------------------------------------------
# Subprojects : Sources/Libraries/Linker Directives
# ----------------------------------------------------------------------------------------------------------------------------------
sub/ehvm_bsw.gpj

