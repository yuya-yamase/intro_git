#!gbuild
[Options File]
    :macro=IOHW_ADC_SCC_DIR=${IOHW_DIR}/iohw_adc/scc
    :macro=IOHW_DIFIL_SCC_DIR=${IOHW_DIR}/iohw_diflt/scc

    :macro=IOHW_ADC_CFG_DIR=${IOHW_DIR}/iohw_adc/config_CDC_US
    :macro=IOHW_DIFIL_CFG_DIR=${IOHW_DIR}/iohw_diflt/config_CDC

    -I${IOHW_ADC_SCC_DIR}
    -I${IOHW_ADC_CFG_DIR}
    -I${IOHW_DIFIL_SCC_DIR}
    -I${IOHW_DIFIL_CFG_DIR}
