primaryTarget=v800_standalone.tgt
[Program]
    :optionsFile=../ghs_ccal_rh850g4mh.opt
    -object_dir=obj/pe3vm3

    -o dst/pe3vm3.elf

    :macro=GCLI_PAR="0x005f0000 0x007bfddf 0xff -start 0x005f0000 -end 0x007bfddf"
    :macro=GCLI_MOT="gsrec -sort -S3 -noS5 -bytes 16 -pad1"
    :macro=GCLI_BIN="gmemfile -fill1"

    :postexec="${GCLI_MOT} ${GCLI_PAR}                     -o dst/pe3vm3_ac.mot dst/pe3vm3.elf"
    :postexec="${GCLI_MOT} ${GCLI_PAR} -romaddr 0x025f0000 -o dst/pe3vm3_bd.mot dst/pe3vm3.elf"
    :postexec="${GCLI_BIN} ${GCLI_PAR}                     -o dst/pe3vm3.bin dst/pe3vm3.elf"

