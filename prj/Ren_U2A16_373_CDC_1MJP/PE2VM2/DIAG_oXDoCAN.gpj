    -I${CAN_DIR}/Dcm/Dsp/cfg
    -I${CAN_DIR}/Dcm/Dsp/inc
    -I${CAN_DIR}/Dcm/Dsl/usr
    -I${CAN_DIR}/Dcm/Main/cfg
    -I${CAN_DIR}/Dcm/Main/inc
    -I${CAN_DIR}/Dem/cfg
    -I${CAN_DIR}/Dem/usr

    -I${CAN_DIR}/CS/inc
    
    -I${APP_DIR}/IVI/DiagApp

