    :macro=MCAL_I2C_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/I2C/scc
    :macro=MCAL_ICU_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/Icu/scc
    :macro=MCAL_INTC_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/Intc/scc
