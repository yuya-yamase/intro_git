    :macro=MCAL_WDG_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/Wdg/scc

    :macro=MCAL_ADC_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/ADC/config_CDC_OT
    :macro=MCAL_ADCDIAG_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/ADCDIAG/config_CDC
    :macro=MCAL_COMMON_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/COMMON/config_CDC
