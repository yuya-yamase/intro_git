    :macro=MCAL_I2C_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/I2C/config_CDC
    :macro=MCAL_ICU_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/Icu/config_CDC
    :macro=MCAL_INTC_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/Intc/config_CDC
    :macro=MCAL_MCU_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/MCU/config_CDC
    :macro=MCAL_PORT_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/PORT/config_CDC_2MOT
    :macro=MCAL_TYPORT_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/tyPORT/config_CDC
    :macro=MCAL_PWM_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/Pwm/config_CDC
    :macro=MCAL_SPI_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/SPI/config_CDC
    :macro=MCAL_UART_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/Uart/config_CDC
    :macro=MCAL_WDG_CFG_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/Wdg/config_CDC
    
    :macro=MCAL_SECTION_DIR=${MCAL_DIR}/Ren_U2Ax/A16_373/SECTION/config_CDC

    -I${MCAL_ADC_SCC_DIR}
    -I${MCAL_ADCDIAG_SCC_DIR}
    -I${MCAL_COMMON_SCC_DIR}
    -I${MCAL_DIO_SCC_DIR}
