    :macro=MCAL_DUMMY_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/DUMMY/scc
    :macro=MCAL_ERRH_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/ErrH/scc
