#!gbuild
[Options File]
    -DEcuM_WakeupSourceType=uint32
    -DEcuM_SetWakeupEvent(a)=(void)(a)

    :macro=MCAL_ADC_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/ADC/scc
    :macro=MCAL_ADCDIAG_SCC_DIR=${MCAL_DIR}/Ren_U2Ax/Common/ADCDIAG/scc
