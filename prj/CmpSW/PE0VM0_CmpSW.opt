#!gbuild
[Options File]
# /************************************************************/
#  Compile Switch
# /************************************************************/

# 1Sボード用の定義が有効の場合に使用するマクロ名を以下枠内に記述
#	{isdefined(BOARD_SW_1S)}	-DSAMPLE
# /------------------------------------------------------------/

# /------------------------------------------------------------/

# JP用の定義が有効の場合に使用するマクロ名を以下枠内に記述
#	{isdefined(COUNTRY_SW_JP)}	-DSAMPLE
# /------------------------------------------------------------/
    {isdefined(COUNTRY_SW_JP)}	-DSYS_PWR_ANT_DTV

# /------------------------------------------------------------/

# US用の定義が有効の場合に使用するマクロ名を以下枠内に記述
#	{isdefined(COUNTRY_SW_US)}	-DSAMPLE
# /------------------------------------------------------------/
    {isdefined(COUNTRY_SW_US)}	-DSYS_PWR_ANT_XM_SHDN

# /------------------------------------------------------------/

# /------------------------------------------------------------/

# OTH用の定義が有効の場合に使用するマクロ名を以下枠内に記述
#	{isdefined(COUNTRY_SW_OTH)}	-DSAMPLE
# /------------------------------------------------------------/
    {isdefined(COUNTRY_SW_OTH)}	-DSYS_PWR_ANT_DAB

# /------------------------------------------------------------/