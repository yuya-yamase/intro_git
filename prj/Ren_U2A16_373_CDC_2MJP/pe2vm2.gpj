primaryTarget=v800_standalone.tgt
[Program]
    :optionsFile=../ghs_ccal_rh850g4mh.opt
    -object_dir=obj/pe2vm2

    -o dst/pe2vm2.elf

    :macro=GCLI_PAR="0x00400000 0x005effff 0xff -start 0x00400000 -end 0x005effff"
    :macro=GCLI_MOT="gsrec -sort -S3 -noS5 -bytes 16 -pad1"
    :macro=GCLI_BIN="gmemfile -fill1"

    :postexec="${GCLI_MOT} ${GCLI_PAR}                     -o dst/pe2vm2_ac.mot dst/pe2vm2.elf"
    :postexec="${GCLI_MOT} ${GCLI_PAR} -romaddr 0x02400000 -o dst/pe2vm2_bd.mot dst/pe2vm2.elf"
    :postexec="${GCLI_BIN} ${GCLI_PAR}                     -o dst/pe2vm2.bin dst/pe2vm2.elf"

