                    <ECUC-TEXTUAL-PARAM-VALUE>
                      <DEFINITION-REF DEST="ECUC-ENUMERATION-PARAM-DEF">/Port/Port/PortSetPinConfigSet/PortSetPinNoiseFilter/PortSetPinDetectionMode</DEFINITION-REF>
                      <VALUE>DISABLE_EDGE_DETECTION</VALUE>
                    </ECUC-TEXTUAL-PARAM-VALUE>
                    <ECUC-NUMERICAL-PARAM-VALUE>
                      <DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/Port/Port/PortSetPinConfigSet/PortSetPinNoiseFilter/PortSetPinNumberOfSamples</DEFINITION-REF>
                      <VALUE>2</VALUE>
                    </ECUC-NUMERICAL-PARAM-VALUE>
                    <ECUC-TEXTUAL-PARAM-VALUE>
                      <DEFINITION-REF DEST="ECUC-ENUMERATION-PARAM-DEF">/Port/Port/PortSetPinConfigSet/PortSetPinNoiseFilter/PortSetPinSamplingClockFrequency</DEFINITION-REF>
                      <VALUE>SUPPLY_DEVIDED_BY_1</VALUE>
                    </ECUC-TEXTUAL-PARAM-VALUE>
                  </PARAMETER-VALUES>
                </ECUC-CONTAINER-VALUE>
              </SUB-CONTAINERS>
            </ECUC-CONTAINER-VALUE>
          </CONTAINERS>
        </ECUC-MODULE-CONFIGURATION-VALUES>
      </ELEMENTS>
    </AR-PACKAGE>
  </AR-PACKAGES>
